generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum Role {
  ADMIN
  DOCTOR
  RECEPTION
  NURSE
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  BOOKED
  CHECKED_IN
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  SCHEDULED
  WALK_IN
}

enum Priority {
  NORMAL
  URGENT
  EMERGENCY
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
}

enum PaymentMode {
  CASH
  CARD
  UPI
  ONLINE
  INSURANCE
}

enum ClaimStatus {
  SUBMITTED
  APPROVED
  REJECTED
  SETTLED
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLED
  TOKEN_CALLED
  PRESCRIPTION_READY
  BILL_GENERATED
  PAYMENT_RECEIVED
  SCHEDULE_SUMMARY
  ADMISSION
  DISCHARGE
  LAB_RESULT_READY
  MEDICATION_DUE
  LOW_STOCK_ALERT
}

// ─── PHASE 2 ENUMS ──────────────────────────────────────

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
  TRANSFERRED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
  RESERVED
}

enum WardType {
  GENERAL
  PRIVATE
  SEMI_PRIVATE
  ICU
  NICU
  HDU
  EMERGENCY
  MATERNITY
}

enum MedicationStatus {
  SCHEDULED
  ADMINISTERED
  MISSED
  REFUSED
  HELD
}

enum LabTestStatus {
  ORDERED
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LabResultFlag {
  NORMAL
  LOW
  HIGH
  CRITICAL
}

enum StockMovementType {
  PURCHASE
  DISPENSED
  RETURNED
  EXPIRED
  ADJUSTMENT
  DAMAGED
}

// ─── PHASE 3 ENUMS ──────────────────────────────────────

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
  LIFE_THREATENING
}

enum ConditionStatus {
  ACTIVE
  CONTROLLED
  RESOLVED
  RELAPSED
}

enum DocumentType {
  LAB_REPORT
  IMAGING
  DISCHARGE_SUMMARY
  CONSENT
  INSURANCE
  REFERRAL_LETTER
  ID_PROOF
  OTHER
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  COMPLETED
  DECLINED
  EXPIRED
}

enum SurgeryStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  ON_CALL
}

enum ShiftStatus {
  SCHEDULED
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  RECEIVED
  CANCELLED
}

enum ExpenseCategory {
  SALARY
  UTILITIES
  EQUIPMENT
  MAINTENANCE
  CONSUMABLES
  RENT
  MARKETING
  OTHER
}

// ─── PHASE 4 ENUMS ──────────────────────────────────────

enum TelemedicineStatus {
  SCHEDULED
  WAITING
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELLED
}

enum TriageLevel {
  RESUSCITATION // Level 1 - immediate
  EMERGENT // Level 2 - <10 min
  URGENT // Level 3 - <30 min
  LESS_URGENT // Level 4 - <60 min
  NON_URGENT // Level 5 - routine
}

enum EmergencyStatus {
  WAITING
  TRIAGED
  IN_TREATMENT
  ADMITTED
  DISCHARGED
  TRANSFERRED
  LEFT_WITHOUT_BEING_SEEN
  DECEASED
}

enum BloodGroupType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

enum BloodComponent {
  WHOLE_BLOOD
  PACKED_RED_CELLS
  PLATELETS
  FRESH_FROZEN_PLASMA
  CRYOPRECIPITATE
}

enum BloodUnitStatus {
  AVAILABLE
  RESERVED
  ISSUED
  EXPIRED
  DISCARDED
  IN_TESTING
}

enum AmbulanceStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  OUT_OF_SERVICE
}

enum AmbulanceTripStatus {
  REQUESTED
  DISPATCHED
  ARRIVED_SCENE
  EN_ROUTE_HOSPITAL
  COMPLETED
  CANCELLED
}

enum AssetStatus {
  IN_USE
  IDLE
  UNDER_MAINTENANCE
  RETIRED
  LOST
}

enum MaintenanceType {
  SCHEDULED
  BREAKDOWN
  CALIBRATION
  INSPECTION
}

enum AncVisitType {
  FIRST_VISIT
  ROUTINE
  HIGH_RISK_FOLLOWUP
  SCAN_REVIEW
  DELIVERY
  POSTNATAL
}

enum FeedbackCategory {
  DOCTOR
  NURSE
  RECEPTION
  CLEANLINESS
  FOOD
  WAITING_TIME
  BILLING
  OVERALL
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
  CLOSED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum VisitorPurpose {
  PATIENT_VISIT
  DELIVERY
  APPOINTMENT
  MEETING
  OTHER
}

// ─── USERS & AUTH ───────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String
  name         String
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  doctor                    Doctor?
  patient                   Patient?
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  refreshTokens             RefreshToken[]
  medicationAdministrations MedicationAdministration[]
  nurseRounds               NurseRound[]
  stockMovements            StockMovement[]
  uploadedDocuments         PatientDocument[]
  shifts                    StaffShift[]
  leaveRequests             LeaveRequest[]             @relation("LeaveOwner")
  approvedLeaves            LeaveRequest[]             @relation("LeaveApprover")
  recordedExpenses          Expense[]
  sentMessages              ChatMessage[]              @relation("MessageSender")
  chatParticipants          ChatParticipant[]
  assetAssignments          AssetAssignment[]
  maintenanceLogs           AssetMaintenance[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── DOCTOR ─────────────────────────────────────────────

model Doctor {
  id             String  @id @default(uuid())
  userId         String  @unique
  specialization String?
  qualification  String?
  signatureUrl   String?

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules            DoctorSchedule[]
  scheduleOverrides    ScheduleOverride[]
  appointments         Appointment[]
  prescriptions        Prescription[]
  consultations        Consultation[]
  admissions           Admission[]
  medicationOrders     MedicationOrder[]
  labOrders            LabOrder[]
  referralsFrom        Referral[]            @relation("ReferrerDoctor")
  referralsTo          Referral[]            @relation("RefereeDoctor")
  surgeriesLead        Surgery[]             @relation("LeadSurgeon")
  telemedicineSessions TelemedicineSession[]
  emergencyCases       EmergencyCase[]       @relation("EmergencyAttendingDoctor")
  ancCases             AntenatalCase[]

  @@map("doctors")
}

model DoctorSchedule {
  id                  String @id @default(uuid())
  doctorId            String
  dayOfWeek           Int // 0=Sunday, 6=Saturday
  startTime           String // HH:MM
  endTime             String // HH:MM
  slotDurationMinutes Int    @default(15)

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek, startTime])
  @@map("doctor_schedules")
}

model ScheduleOverride {
  id        String   @id @default(uuid())
  doctorId  String
  date      DateTime @db.Date
  isBlocked Boolean  @default(true)
  startTime String? // HH:MM — if not blocked, override hours
  endTime   String?
  reason    String?

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date])
  @@map("schedule_overrides")
}

// ─── PATIENT ────────────────────────────────────────────

model Patient {
  id                    String    @id @default(uuid())
  userId                String    @unique
  mrNumber              String    @unique
  dateOfBirth           DateTime? @db.Date
  age                   Int?
  gender                Gender
  address               String?
  bloodGroup            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  insuranceProvider     String?
  insurancePolicyNumber String?

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments         Appointment[]
  vitals               Vitals[]
  prescriptions        Prescription[]
  invoices             Invoice[]
  insuranceClaims      InsuranceClaim[]
  admissions           Admission[]
  labOrders            LabOrder[]
  allergies            PatientAllergy[]
  chronicConditions    ChronicCondition[]
  familyHistory        FamilyHistory[]
  immunizations        Immunization[]
  documents            PatientDocument[]
  referralsFrom        Referral[]            @relation("PatientReferrals")
  surgeries            Surgery[]
  packagePurchases     PackagePurchase[]
  telemedicineSessions TelemedicineSession[]
  emergencyCases       EmergencyCase[]
  bloodRequests        BloodRequest[]
  ambulanceTrips       AmbulanceTrip[]
  ancCase              AntenatalCase?
  growthRecords        GrowthRecord[]
  feedbacks            PatientFeedback[]
  complaints           Complaint[]
  visitors             Visitor[]

  @@index([mrNumber])
  @@map("patients")
}

// ─── APPOINTMENTS & QUEUE ───────────────────────────────

model Appointment {
  id          String            @id @default(uuid())
  patientId   String
  doctorId    String
  date        DateTime          @db.Date
  slotStart   String? // HH:MM — null for walk-ins
  slotEnd     String?
  tokenNumber Int
  type        AppointmentType
  status      AppointmentStatus @default(BOOKED)
  priority    Priority          @default(NORMAL)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  vitals       Vitals?
  consultation Consultation?
  prescription Prescription?
  invoice      Invoice?

  @@unique([doctorId, date, tokenNumber])
  @@index([doctorId, date])
  @@index([patientId])
  @@index([date, status])
  @@map("appointments")
}

// ─── OPD — VITALS & CONSULTATION ────────────────────────

model Vitals {
  id                     String   @id @default(uuid())
  appointmentId          String   @unique
  patientId              String
  nurseId                String
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  temperature            Float?
  weight                 Float?
  height                 Float?
  pulseRate              Int?
  spO2                   Int?
  notes                  String?
  recordedAt             DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     Patient     @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("vitals")
}

model Consultation {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  doctorId      String
  notes         String?
  findings      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])

  @@map("consultations")
}

// ─── PRESCRIPTIONS ──────────────────────────────────────

model Prescription {
  id            String    @id @default(uuid())
  appointmentId String    @unique
  patientId     String
  doctorId      String
  diagnosis     String
  advice        String?
  followUpDate  DateTime? @db.Date
  signatureUrl  String?
  pdfUrl        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment Appointment        @relation(fields: [appointmentId], references: [id])
  patient     Patient            @relation(fields: [patientId], references: [id])
  doctor      Doctor             @relation(fields: [doctorId], references: [id])
  items       PrescriptionItem[]

  @@index([patientId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String  @id @default(uuid())
  prescriptionId String
  medicineName   String
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@map("prescription_items")
}

// ─── BILLING ────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  appointmentId  String        @unique
  patientId      String
  subtotal       Float
  taxAmount      Float         @default(0)
  discountAmount Float         @default(0)
  totalAmount    Float
  paymentStatus  PaymentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  appointment     Appointment      @relation(fields: [appointmentId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])
  items           InvoiceItem[]
  payments        Payment[]
  insuranceClaims InsuranceClaim[]

  @@index([patientId])
  @@index([invoiceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id          String @id @default(uuid())
  invoiceId   String
  description String
  category    String
  quantity    Int    @default(1)
  unitPrice   Float
  amount      Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id            String      @id @default(uuid())
  invoiceId     String
  amount        Float
  mode          PaymentMode
  transactionId String?
  paidAt        DateTime    @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model InsuranceClaim {
  id                String      @id @default(uuid())
  invoiceId         String
  patientId         String
  insuranceProvider String
  policyNumber      String
  claimAmount       Float
  approvedAmount    Float?
  status            ClaimStatus @default(SUBMITTED)
  submittedAt       DateTime    @default(now())
  resolvedAt        DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([invoiceId])
  @@index([patientId])
  @@map("insurance_claims")
}

// ─── NOTIFICATIONS ──────────────────────────────────────

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel
  title     String
  message   String
  data      Json?
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id      String              @id @default(uuid())
  userId  String
  channel NotificationChannel
  enabled Boolean             @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("notification_preferences")
}

// ─── AUDIT ──────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── SYSTEM ─────────────────────────────────────────────

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("system_config")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: IPD / INPATIENT MANAGEMENT
// ═══════════════════════════════════════════════════════

model Ward {
  id          String   @id @default(uuid())
  name        String   @unique
  type        WardType
  floor       String?
  description String?
  createdAt   DateTime @default(now())

  beds Bed[]

  @@map("wards")
}

model Bed {
  id        String    @id @default(uuid())
  wardId    String
  bedNumber String
  status    BedStatus @default(AVAILABLE)
  dailyRate Float     @default(0)
  notes     String?

  ward       Ward        @relation(fields: [wardId], references: [id])
  admissions Admission[]

  @@unique([wardId, bedNumber])
  @@index([status])
  @@map("beds")
}

model Admission {
  id               String          @id @default(uuid())
  admissionNumber  String          @unique
  patientId        String
  doctorId         String
  bedId            String
  status           AdmissionStatus @default(ADMITTED)
  admittedAt       DateTime        @default(now())
  dischargedAt     DateTime?
  reason           String
  diagnosis        String?
  dischargeSummary String?
  dischargeNotes   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  patient          Patient           @relation(fields: [patientId], references: [id])
  doctor           Doctor            @relation(fields: [doctorId], references: [id])
  bed              Bed               @relation(fields: [bedId], references: [id])
  ipdVitals        IpdVitals[]
  medicationOrders MedicationOrder[]
  nurseRounds      NurseRound[]
  labOrders        LabOrder[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@map("admissions")
}

model IpdVitals {
  id                     String   @id @default(uuid())
  admissionId            String
  recordedBy             String // user id
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  temperature            Float?
  pulseRate              Int?
  respiratoryRate        Int?
  spO2                   Int?
  painScore              Int?
  bloodSugar             Int?
  notes                  String?
  recordedAt             DateTime @default(now())

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([admissionId, recordedAt])
  @@map("ipd_vitals")
}

model MedicationOrder {
  id           String    @id @default(uuid())
  admissionId  String
  doctorId     String
  medicineId   String? // link to medicine catalog
  medicineName String
  dosage       String
  frequency    String // e.g. "every 6 hours", "BID", "TID"
  route        String // oral, IV, IM, SC, topical
  startDate    DateTime  @default(now())
  endDate      DateTime?
  instructions String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  admission       Admission                  @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  doctor          Doctor                     @relation(fields: [doctorId], references: [id])
  medicine        Medicine?                  @relation(fields: [medicineId], references: [id])
  administrations MedicationAdministration[]

  @@index([admissionId])
  @@index([isActive])
  @@map("medication_orders")
}

model MedicationAdministration {
  id                String           @id @default(uuid())
  medicationOrderId String
  scheduledAt       DateTime
  administeredAt    DateTime?
  administeredBy    String? // nurse user id
  status            MedicationStatus @default(SCHEDULED)
  notes             String?

  medicationOrder MedicationOrder @relation(fields: [medicationOrderId], references: [id], onDelete: Cascade)
  nurse           User?           @relation(fields: [administeredBy], references: [id])

  @@index([medicationOrderId])
  @@index([scheduledAt, status])
  @@map("medication_administrations")
}

model NurseRound {
  id          String   @id @default(uuid())
  admissionId String
  nurseId     String
  notes       String
  performedAt DateTime @default(now())

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  nurse     User      @relation(fields: [nurseId], references: [id])

  @@index([admissionId])
  @@index([performedAt])
  @@map("nurse_rounds")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: MEDICINE DATABASE & DRUG INTERACTIONS
// ═══════════════════════════════════════════════════════

model Medicine {
  id                   String   @id @default(uuid())
  name                 String   @unique
  genericName          String?
  brand                String?
  form                 String? // tablet, syrup, injection, etc.
  strength             String? // "500mg", "250mg/5ml"
  category             String? // antibiotic, analgesic, etc.
  description          String?
  sideEffects          String?
  contraindications    String?
  prescriptionRequired Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  medicationOrders MedicationOrder[]
  interactionsA    DrugInteraction[] @relation("DrugA")
  interactionsB    DrugInteraction[] @relation("DrugB")
  inventoryItems   InventoryItem[]

  @@index([name])
  @@index([category])
  @@map("medicines")
}

model DrugInteraction {
  id          String @id @default(uuid())
  drugAId     String
  drugBId     String
  severity    String // MILD, MODERATE, SEVERE, CONTRAINDICATED
  description String

  drugA Medicine @relation("DrugA", fields: [drugAId], references: [id], onDelete: Cascade)
  drugB Medicine @relation("DrugB", fields: [drugBId], references: [id], onDelete: Cascade)

  @@unique([drugAId, drugBId])
  @@map("drug_interactions")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: PHARMACY INVENTORY
// ═══════════════════════════════════════════════════════

model InventoryItem {
  id           String   @id @default(uuid())
  medicineId   String
  batchNumber  String
  quantity     Int // current stock
  unitCost     Float // purchase cost per unit
  sellingPrice Float
  expiryDate   DateTime @db.Date
  supplier     String?
  reorderLevel Int      @default(10)
  location     String? // shelf/rack location
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  medicine  Medicine        @relation(fields: [medicineId], references: [id])
  movements StockMovement[]

  @@unique([medicineId, batchNumber])
  @@index([expiryDate])
  @@map("inventory_items")
}

model StockMovement {
  id              String            @id @default(uuid())
  inventoryItemId String
  type            StockMovementType
  quantity        Int // positive for in, negative for out
  referenceId     String? // e.g., prescription id, purchase order id
  reason          String?
  performedBy     String // user id
  createdAt       DateTime          @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  user          User          @relation(fields: [performedBy], references: [id])

  @@index([inventoryItemId])
  @@index([createdAt])
  @@map("stock_movements")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: LAB TESTS
// ═══════════════════════════════════════════════════════

model LabTest {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., CBC, LFT
  name        String
  category    String? // Hematology, Biochemistry, Microbiology, etc.
  price       Float
  sampleType  String? // Blood, Urine, Stool
  normalRange String? // Free text for reference ranges
  description String?
  createdAt   DateTime @default(now())

  orderItems LabOrderItem[]

  @@index([code])
  @@index([category])
  @@map("lab_tests")
}

model LabOrder {
  id          String        @id @default(uuid())
  orderNumber String        @unique
  patientId   String
  doctorId    String
  admissionId String? // null for OPD
  status      LabTestStatus @default(ORDERED)
  notes       String?
  orderedAt   DateTime      @default(now())
  collectedAt DateTime?
  completedAt DateTime?

  patient   Patient        @relation(fields: [patientId], references: [id])
  doctor    Doctor         @relation(fields: [doctorId], references: [id])
  admission Admission?     @relation(fields: [admissionId], references: [id])
  items     LabOrderItem[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@map("lab_orders")
}

model LabOrderItem {
  id      String        @id @default(uuid())
  orderId String
  testId  String
  status  LabTestStatus @default(ORDERED)
  results LabResult[]

  order LabOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  test  LabTest  @relation(fields: [testId], references: [id])

  @@map("lab_order_items")
}

model LabResult {
  id          String        @id @default(uuid())
  orderItemId String
  parameter   String // e.g., "Hemoglobin", "WBC Count"
  value       String
  unit        String?
  normalRange String?
  flag        LabResultFlag @default(NORMAL)
  notes       String?
  enteredBy   String // user id
  reportedAt  DateTime      @default(now())

  orderItem LabOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("lab_results")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: ELECTRONIC HEALTH RECORDS (EHR)
// ═══════════════════════════════════════════════════════

model PatientAllergy {
  id        String          @id @default(uuid())
  patientId String
  allergen  String
  severity  AllergySeverity @default(MILD)
  reaction  String?
  notes     String?
  notedBy   String // user id
  notedAt   DateTime        @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_allergies")
}

model ChronicCondition {
  id            String          @id @default(uuid())
  patientId     String
  condition     String
  icd10Code     String?
  diagnosedDate DateTime?       @db.Date
  status        ConditionStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("chronic_conditions")
}

model FamilyHistory {
  id        String  @id @default(uuid())
  patientId String
  relation  String // Mother, Father, Sibling, etc.
  condition String
  notes     String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("family_history")
}

model Immunization {
  id             String    @id @default(uuid())
  patientId      String
  vaccine        String
  doseNumber     Int?
  dateGiven      DateTime  @db.Date
  administeredBy String? // user id or external provider
  batchNumber    String?
  manufacturer   String?
  site           String? // left arm, etc.
  nextDueDate    DateTime? @db.Date
  notes          String?
  createdAt      DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([nextDueDate])
  @@map("immunizations")
}

model PatientDocument {
  id         String       @id @default(uuid())
  patientId  String
  type       DocumentType
  title      String
  filePath   String // server file path or URL
  fileSize   Int? // bytes
  mimeType   String?
  uploadedBy String // user id
  notes      String?
  createdAt  DateTime     @default(now())

  patient  Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploadedBy], references: [id])

  @@index([patientId])
  @@index([type])
  @@map("patient_documents")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: REFERRALS
// ═══════════════════════════════════════════════════════

model Referral {
  id               String         @id @default(uuid())
  referralNumber   String         @unique
  patientId        String
  fromDoctorId     String
  toDoctorId       String? // null if external
  externalProvider String? // external hospital/specialist name
  externalContact  String?
  specialty        String?
  reason           String
  notes            String?
  status           ReferralStatus @default(PENDING)
  referredAt       DateTime       @default(now())
  respondedAt      DateTime?

  patient    Patient @relation("PatientReferrals", fields: [patientId], references: [id])
  fromDoctor Doctor  @relation("ReferrerDoctor", fields: [fromDoctorId], references: [id])
  toDoctor   Doctor? @relation("RefereeDoctor", fields: [toDoctorId], references: [id])

  @@index([patientId])
  @@index([fromDoctorId])
  @@index([status])
  @@map("referrals")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: SURGERY / OPERATION THEATER
// ═══════════════════════════════════════════════════════

model OperatingTheater {
  id        String  @id @default(uuid())
  name      String  @unique
  floor     String?
  equipment String?
  dailyRate Float   @default(0)
  isActive  Boolean @default(true)

  surgeries Surgery[]

  @@map("operating_theaters")
}

model Surgery {
  id                String        @id @default(uuid())
  caseNumber        String        @unique
  patientId         String
  surgeonId         String
  otId              String
  procedure         String
  scheduledAt       DateTime
  durationMin       Int? // estimated duration
  actualStartAt     DateTime?
  actualEndAt       DateTime?
  status            SurgeryStatus @default(SCHEDULED)
  anaesthesiologist String?
  assistants        String? // comma-separated names or JSON
  preOpNotes        String?
  postOpNotes       String?
  diagnosis         String?
  cost              Float?        @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  patient Patient          @relation(fields: [patientId], references: [id])
  surgeon Doctor           @relation("LeadSurgeon", fields: [surgeonId], references: [id])
  ot      OperatingTheater @relation(fields: [otId], references: [id])

  @@index([patientId])
  @@index([surgeonId])
  @@index([scheduledAt])
  @@index([status])
  @@map("surgeries")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: STAFF HR (SHIFTS & LEAVE)
// ═══════════════════════════════════════════════════════

model StaffShift {
  id        String      @id @default(uuid())
  userId    String
  date      DateTime    @db.Date
  type      ShiftType
  startTime String // HH:MM
  endTime   String
  status    ShiftStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
  @@index([date])
  @@index([status])
  @@map("staff_shifts")
}

model LeaveRequest {
  id              String      @id @default(uuid())
  userId          String
  type            LeaveType
  fromDate        DateTime    @db.Date
  toDate          DateTime    @db.Date
  totalDays       Int
  reason          String
  status          LeaveStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user     User  @relation("LeaveOwner", fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("LeaveApprover", fields: [approvedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@map("leave_requests")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: FINANCE EXPANSION
// ═══════════════════════════════════════════════════════

model HealthPackage {
  id            String   @id @default(uuid())
  name          String
  description   String?
  services      String // comma-separated list or JSON
  price         Float
  discountPrice Float?
  validityDays  Int      @default(365)
  category      String? // Master Checkup, Diabetes Package, etc.
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchases PackagePurchase[]

  @@index([category])
  @@map("health_packages")
}

model PackagePurchase {
  id             String   @id @default(uuid())
  purchaseNumber String   @unique
  packageId      String
  patientId      String
  purchasedAt    DateTime @default(now())
  expiresAt      DateTime
  amountPaid     Float
  servicesUsed   String? // JSON tracking which services consumed
  isFullyUsed    Boolean  @default(false)

  package HealthPackage @relation(fields: [packageId], references: [id])
  patient Patient       @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([packageId])
  @@map("package_purchases")
}

model Supplier {
  id            String   @id @default(uuid())
  name          String   @unique
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  gstNumber     String?
  paymentTerms  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  poNumber    String              @unique
  supplierId  String
  status      PurchaseOrderStatus @default(DRAFT)
  orderedAt   DateTime            @default(now())
  expectedAt  DateTime?
  receivedAt  DateTime?
  subtotal    Float
  taxAmount   Float               @default(0)
  totalAmount Float
  notes       String?
  createdBy   String? // user id
  approvedBy  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String  @id @default(uuid())
  poId        String
  description String // item name/description
  medicineId  String?
  quantity    Int
  unitPrice   Float
  amount      Float

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
  @@map("purchase_order_items")
}

model Expense {
  id             String          @id @default(uuid())
  category       ExpenseCategory
  amount         Float
  description    String
  date           DateTime        @db.Date
  paidTo         String?
  paidBy         String // user id
  referenceNo    String?
  attachmentPath String?
  createdAt      DateTime        @default(now())

  user User @relation(fields: [paidBy], references: [id])

  @@index([date])
  @@index([category])
  @@map("expenses")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: TELEMEDICINE
// ═══════════════════════════════════════════════════════

model TelemedicineSession {
  id             String             @id @default(uuid())
  sessionNumber  String             @unique
  patientId      String
  doctorId       String
  scheduledAt    DateTime
  startedAt      DateTime?
  endedAt        DateTime?
  durationMin    Int?
  meetingUrl     String?
  meetingId      String?
  status         TelemedicineStatus @default(SCHEDULED)
  chiefComplaint String?
  doctorNotes    String?
  patientRating  Int? // 1-5
  prescriptionId String?
  fee            Float              @default(500)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@map("telemedicine_sessions")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: EMERGENCY / TRIAGE
// ═══════════════════════════════════════════════════════

model EmergencyCase {
  id                String          @id @default(uuid())
  caseNumber        String          @unique
  patientId         String? // null if unknown/unregistered
  unknownName       String? // for Jane/John Does
  unknownAge        Int?
  unknownGender     String?
  arrivedAt         DateTime        @default(now())
  arrivalMode       String? // Walk-in, Ambulance, Police, Referred
  triageLevel       TriageLevel?
  triagedAt         DateTime?
  triagedBy         String? // user id
  chiefComplaint    String
  mewsScore         Int? // Modified Early Warning Score (0-14)
  vitalsBP          String?
  vitalsPulse       Int?
  vitalsResp        Int?
  vitalsSpO2        Int?
  vitalsTemp        Float?
  glasgowComa       Int? // GCS 3-15
  attendingDoctorId String?
  seenAt            DateTime?
  status            EmergencyStatus @default(WAITING)
  disposition       String? // admit, discharge, transfer, dama
  outcomeNotes      String?
  closedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  patient         Patient? @relation(fields: [patientId], references: [id])
  attendingDoctor Doctor?  @relation("EmergencyAttendingDoctor", fields: [attendingDoctorId], references: [id])

  @@index([status])
  @@index([triageLevel])
  @@index([arrivedAt])
  @@map("emergency_cases")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: BLOOD BANK
// ═══════════════════════════════════════════════════════

model BloodDonor {
  id             String         @id @default(uuid())
  donorNumber    String         @unique
  name           String
  phone          String
  email          String?
  bloodGroup     BloodGroupType
  dateOfBirth    DateTime?      @db.Date
  gender         Gender
  weight         Float?
  address        String?
  lastDonation   DateTime?      @db.Date
  totalDonations Int            @default(0)
  isEligible     Boolean        @default(true)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  donations BloodDonation[]

  @@index([bloodGroup])
  @@index([phone])
  @@map("blood_donors")
}

model BloodDonation {
  id             String   @id @default(uuid())
  donorId        String
  donatedAt      DateTime @default(now())
  volumeMl       Int      @default(450)
  unitNumber     String   @unique
  screeningNotes String?
  approved       Boolean  @default(false)
  approvedBy     String?
  createdAt      DateTime @default(now())

  donor BloodDonor  @relation(fields: [donorId], references: [id])
  units BloodUnit[]

  @@index([donorId])
  @@map("blood_donations")
}

model BloodUnit {
  id              String          @id @default(uuid())
  unitNumber      String          @unique
  donationId      String?
  bloodGroup      BloodGroupType
  component       BloodComponent
  volumeMl        Int
  collectedAt     DateTime
  expiresAt       DateTime
  status          BloodUnitStatus @default(AVAILABLE)
  storageLocation String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  donation BloodDonation? @relation(fields: [donationId], references: [id])
  requests BloodRequest[]

  @@index([bloodGroup, component, status])
  @@index([expiresAt])
  @@map("blood_units")
}

model BloodRequest {
  id             String         @id @default(uuid())
  requestNumber  String         @unique
  patientId      String
  bloodGroup     BloodGroupType
  component      BloodComponent
  unitsRequested Int
  reason         String
  urgency        String // ROUTINE, URGENT, EMERGENCY
  requestedBy    String // user id
  issuedAt       DateTime?
  issuedBy       String?
  fulfilled      Boolean        @default(false)
  notes          String?
  createdAt      DateTime       @default(now())

  patient Patient     @relation(fields: [patientId], references: [id])
  units   BloodUnit[]

  @@index([patientId])
  @@index([fulfilled])
  @@map("blood_requests")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: AMBULANCE MANAGEMENT
// ═══════════════════════════════════════════════════════

model Ambulance {
  id              String          @id @default(uuid())
  vehicleNumber   String          @unique
  make            String?
  model           String?
  type            String // BLS (Basic Life Support), ALS (Advanced), ICU, Patient Transport
  status          AmbulanceStatus @default(AVAILABLE)
  driverName      String?
  driverPhone     String?
  paramedicName   String?
  lastServiceDate DateTime?       @db.Date
  nextServiceDate DateTime?       @db.Date
  notes           String?
  createdAt       DateTime        @default(now())

  trips AmbulanceTrip[]

  @@map("ambulances")
}

model AmbulanceTrip {
  id             String              @id @default(uuid())
  tripNumber     String              @unique
  ambulanceId    String
  patientId      String?
  callerName     String?
  callerPhone    String?
  pickupAddress  String
  dropAddress    String?
  distanceKm     Float?
  chiefComplaint String?
  requestedAt    DateTime            @default(now())
  dispatchedAt   DateTime?
  arrivedAt      DateTime?
  completedAt    DateTime?
  status         AmbulanceTripStatus @default(REQUESTED)
  cost           Float?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  ambulance Ambulance @relation(fields: [ambulanceId], references: [id])
  patient   Patient?  @relation(fields: [patientId], references: [id])

  @@index([ambulanceId])
  @@index([status])
  @@index([requestedAt])
  @@map("ambulance_trips")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: ASSET MANAGEMENT
// ═══════════════════════════════════════════════════════

model Asset {
  id             String      @id @default(uuid())
  assetTag       String      @unique
  name           String
  category       String // Medical Equipment, IT, Furniture, Vehicle
  manufacturer   String?
  modelNumber    String?
  serialNumber   String?
  purchaseDate   DateTime?   @db.Date
  purchaseCost   Float?
  warrantyExpiry DateTime?   @db.Date
  location       String?
  department     String?
  status         AssetStatus @default(IDLE)
  amcProvider    String?
  amcExpiryDate  DateTime?   @db.Date
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  assignments AssetAssignment[]
  maintenance AssetMaintenance[]

  @@index([category])
  @@index([status])
  @@map("assets")
}

model AssetAssignment {
  id         String    @id @default(uuid())
  assetId    String
  assignedTo String // user id
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  location   String?
  notes      String?

  asset    Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignee User  @relation(fields: [assignedTo], references: [id])

  @@index([assetId])
  @@index([assignedTo])
  @@map("asset_assignments")
}

model AssetMaintenance {
  id          String          @id @default(uuid())
  assetId     String
  type        MaintenanceType
  performedAt DateTime        @default(now())
  performedBy String // user id
  vendor      String?
  cost        Float?          @default(0)
  description String
  nextDueDate DateTime?       @db.Date
  createdAt   DateTime        @default(now())

  asset      Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  technician User  @relation(fields: [performedBy], references: [id])

  @@index([assetId])
  @@index([nextDueDate])
  @@map("asset_maintenance")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: MATERNITY / ANTENATAL CARE
// ═══════════════════════════════════════════════════════

model AntenatalCase {
  id           String    @id @default(uuid())
  caseNumber   String    @unique
  patientId    String    @unique // one active ANC case per patient
  doctorId     String
  lmpDate      DateTime  @db.Date // Last Menstrual Period
  eddDate      DateTime  @db.Date // Expected Delivery Date
  gravida      Int       @default(1)
  parity       Int       @default(0)
  bloodGroup   String?
  isHighRisk   Boolean   @default(false)
  riskFactors  String?
  deliveredAt  DateTime?
  deliveryType String? // NORMAL, C_SECTION, INSTRUMENTAL
  babyGender   String?
  babyWeight   Float?
  outcomeNotes String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient Patient    @relation(fields: [patientId], references: [id])
  doctor  Doctor     @relation(fields: [doctorId], references: [id])
  visits  AncVisit[]

  @@map("antenatal_cases")
}

model AncVisit {
  id               String       @id @default(uuid())
  ancCaseId        String
  type             AncVisitType
  visitDate        DateTime     @default(now())
  weeksOfGestation Int?
  weight           Float?
  bloodPressure    String?
  fundalHeight     String? // cm
  fetalHeartRate   Int?
  presentation     String?
  hemoglobin       Float?
  urineProtein     String?
  urineSugar       String?
  notes            String?
  prescribedMeds   String?
  nextVisitDate    DateTime?    @db.Date
  createdAt        DateTime     @default(now())

  ancCase AntenatalCase @relation(fields: [ancCaseId], references: [id], onDelete: Cascade)

  @@index([ancCaseId])
  @@map("anc_visits")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: PEDIATRIC GROWTH
// ═══════════════════════════════════════════════════════

model GrowthRecord {
  id                 String   @id @default(uuid())
  patientId          String
  measurementDate    DateTime @default(now()) @db.Date
  ageMonths          Int
  weightKg           Float?
  heightCm           Float?
  headCircumference  Float? // cm
  bmi                Float?
  weightPercentile   Float? // 0-100
  heightPercentile   Float?
  milestoneNotes     String?
  developmentalNotes String?
  recordedBy         String
  createdAt          DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, measurementDate])
  @@map("growth_records")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: PATIENT FEEDBACK & COMPLAINTS
// ═══════════════════════════════════════════════════════

model PatientFeedback {
  id          String           @id @default(uuid())
  patientId   String
  category    FeedbackCategory
  rating      Int // 1-5
  nps         Int? // 0-10 Net Promoter Score
  comment     String?
  submittedAt DateTime         @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([category])
  @@index([submittedAt])
  @@map("patient_feedback")
}

model Complaint {
  id           String          @id @default(uuid())
  ticketNumber String          @unique
  patientId    String?
  name         String? // for anonymous
  phone        String?
  category     String
  description  String
  status       ComplaintStatus @default(OPEN)
  assignedTo   String? // user id
  resolution   String?
  resolvedAt   DateTime?
  priority     String          @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  patient Patient? @relation(fields: [patientId], references: [id])

  @@index([status])
  @@index([assignedTo])
  @@map("complaints")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: INTERNAL CHAT / MESSAGING
// ═══════════════════════════════════════════════════════

model ChatRoom {
  id            String    @id @default(uuid())
  name          String?
  isGroup       Boolean   @default(false)
  createdBy     String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@map("chat_rooms")
}

model ChatParticipant {
  id         String    @id @default(uuid())
  roomId     String
  userId     String
  joinedAt   DateTime  @default(now())
  leftAt     DateTime?
  lastReadAt DateTime?

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model ChatMessage {
  id            String      @id @default(uuid())
  roomId        String
  senderId      String
  type          MessageType @default(TEXT)
  content       String
  attachmentUrl String?
  editedAt      DateTime?
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("MessageSender", fields: [senderId], references: [id])

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: VISITOR MANAGEMENT
// ═══════════════════════════════════════════════════════

model Visitor {
  id            String         @id @default(uuid())
  passNumber    String         @unique
  name          String
  phone         String?
  idProofType   String?
  idProofNumber String?
  patientId     String?
  purpose       VisitorPurpose
  department    String?
  checkInAt     DateTime       @default(now())
  checkOutAt    DateTime?
  notes         String?
  createdAt     DateTime       @default(now())

  patient Patient? @relation(fields: [patientId], references: [id])

  @@index([checkInAt])
  @@index([patientId])
  @@map("visitors")
}
