generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum Role {
  ADMIN
  DOCTOR
  RECEPTION
  NURSE
  PATIENT
  PHARMACIST
  LAB_TECH
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  BOOKED
  CHECKED_IN
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  SCHEDULED
  WALK_IN
}

enum Priority {
  NORMAL
  URGENT
  EMERGENCY
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
}

enum PaymentMode {
  CASH
  CARD
  UPI
  ONLINE
  INSURANCE
}

enum PaymentTxnStatus {
  CAPTURED
  FAILED
  REFUNDED
}

enum ClaimStatus {
  SUBMITTED
  APPROVED
  REJECTED
  SETTLED
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLED
  TOKEN_CALLED
  PRESCRIPTION_READY
  BILL_GENERATED
  PAYMENT_RECEIVED
  SCHEDULE_SUMMARY
  ADMISSION
  DISCHARGE
  LAB_RESULT_READY
  MEDICATION_DUE
  LOW_STOCK_ALERT
}

// ─── PHASE 2 ENUMS ──────────────────────────────────────

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
  TRANSFERRED
}

enum AdmissionType {
  ELECTIVE
  EMERGENCY
  TRANSFER
  MATERNITY
  DAY_CARE
}

enum IntakeOutputType {
  INTAKE_ORAL
  INTAKE_IV
  INTAKE_NG
  OUTPUT_URINE
  OUTPUT_STOOL
  OUTPUT_VOMIT
  OUTPUT_DRAIN
  OUTPUT_OTHER
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
  RESERVED
}

enum WardType {
  GENERAL
  PRIVATE
  SEMI_PRIVATE
  ICU
  NICU
  HDU
  EMERGENCY
  MATERNITY
}

enum MedicationStatus {
  SCHEDULED
  ADMINISTERED
  MISSED
  REFUSED
  HELD
}

enum LabTestStatus {
  ORDERED
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  SAMPLE_REJECTED
}

enum LabResultFlag {
  NORMAL
  LOW
  HIGH
  CRITICAL
}

enum StockMovementType {
  PURCHASE
  DISPENSED
  RETURNED
  EXPIRED
  ADJUSTMENT
  DAMAGED
}

// ─── PHASE 3 ENUMS ──────────────────────────────────────

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
  LIFE_THREATENING
}

enum ConditionStatus {
  ACTIVE
  CONTROLLED
  RESOLVED
  RELAPSED
}

enum DocumentType {
  LAB_REPORT
  IMAGING
  DISCHARGE_SUMMARY
  CONSENT
  INSURANCE
  REFERRAL_LETTER
  ID_PROOF
  OTHER
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  COMPLETED
  DECLINED
  EXPIRED
}

enum SurgeryStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  ON_CALL
}

enum ShiftStatus {
  SCHEDULED
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  RECEIVED
  CANCELLED
}

enum ExpenseCategory {
  SALARY
  UTILITIES
  EQUIPMENT
  MAINTENANCE
  CONSUMABLES
  RENT
  MARKETING
  OTHER
}

// ─── PHASE 4 ENUMS ──────────────────────────────────────

enum TelemedicineStatus {
  SCHEDULED
  WAITING
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELLED
}

enum TriageLevel {
  RESUSCITATION // Level 1 - immediate
  EMERGENT // Level 2 - <10 min
  URGENT // Level 3 - <30 min
  LESS_URGENT // Level 4 - <60 min
  NON_URGENT // Level 5 - routine
}

enum EmergencyStatus {
  WAITING
  TRIAGED
  IN_TREATMENT
  ADMITTED
  DISCHARGED
  TRANSFERRED
  LEFT_WITHOUT_BEING_SEEN
  DECEASED
}

enum BloodGroupType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

enum BloodComponent {
  WHOLE_BLOOD
  PACKED_RED_CELLS
  PLATELETS
  FRESH_FROZEN_PLASMA
  CRYOPRECIPITATE
}

enum BloodUnitStatus {
  AVAILABLE
  RESERVED
  ISSUED
  EXPIRED
  DISCARDED
  IN_TESTING
}

enum AmbulanceStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  OUT_OF_SERVICE
}

enum AmbulanceTripStatus {
  REQUESTED
  DISPATCHED
  ARRIVED_SCENE
  EN_ROUTE_HOSPITAL
  COMPLETED
  CANCELLED
}

enum AssetStatus {
  IN_USE
  IDLE
  UNDER_MAINTENANCE
  RETIRED
  LOST
}

enum MaintenanceType {
  SCHEDULED
  BREAKDOWN
  CALIBRATION
  INSPECTION
}

enum AncVisitType {
  FIRST_VISIT
  ROUTINE
  HIGH_RISK_FOLLOWUP
  SCAN_REVIEW
  DELIVERY
  POSTNATAL
}

enum FeedbackCategory {
  DOCTOR
  NURSE
  RECEPTION
  CLEANLINESS
  FOOD
  WAITING_TIME
  BILLING
  OVERALL
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
  CLOSED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum VisitorPurpose {
  PATIENT_VISIT
  DELIVERY
  APPOINTMENT
  MEETING
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RecurringFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SentimentLabel {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum NotificationDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum TenantPlan {
  BASIC
  PRO
  ENTERPRISE
}

// ─── MULTI-TENANCY ──────────────────────────────────────

model Tenant {
  id        String     @id @default(uuid())
  name      String
  subdomain String     @unique
  plan      TenantPlan @default(BASIC)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users                User[]
  doctors              Doctor[]
  patients             Patient[]
  appointments         Appointment[]
  consultations        Consultation[]
  prescriptions        Prescription[]
  invoices             Invoice[]
  payments             Payment[]
  labOrders            LabOrder[]
  labResults           LabResult[]
  admissions           Admission[]
  medicationOrders     MedicationOrder[]
  nurseRounds          NurseRound[]
  referrals            Referral[]
  surgeries            Surgery[]
  staffShifts          StaffShift[]
  leaveRequests        LeaveRequest[]
  telemedicineSessions TelemedicineSession[]
  emergencyCases       EmergencyCase[]
  notifications        Notification[]

  @@map("tenants")
}

// ─── USERS & AUTH ───────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String
  name         String
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  photoUrl     String?
  twoFactorEnabled     Boolean @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes Json?
  preferredLanguage    String?
  defaultLandingPage   String?
  pushToken            String?
  pushPlatform         String?
  pushTokenUpdatedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  doctor                    Doctor?
  patient                   Patient?
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  refreshTokens             RefreshToken[]
  medicationAdministrations MedicationAdministration[]
  nurseRounds               NurseRound[]
  stockMovements            StockMovement[]
  uploadedDocuments         PatientDocument[]
  shifts                    StaffShift[]
  leaveRequests             LeaveRequest[]             @relation("LeaveOwner")
  approvedLeaves            LeaveRequest[]             @relation("LeaveApprover")
  recordedExpenses          Expense[]
  sentMessages              ChatMessage[]              @relation("MessageSender")
  chatParticipants          ChatParticipant[]
  assetAssignments          AssetAssignment[]
  maintenanceLogs           AssetMaintenance[]
  controlledDispenses       ControlledSubstanceEntry[]
  labQcEntries              LabQCEntry[]
  certifications            StaffCertification[]
  overtimeRecords           OvertimeRecord[]
  passwordResetCodes        PasswordResetCode[]
  twoFactorTempTokens       TwoFactorTempToken[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([tenantId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetCode {
  id        String    @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_codes")
}

model TwoFactorTempToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("two_factor_temp_tokens")
}

// ─── DOCTOR ─────────────────────────────────────────────

model Doctor {
  id             String  @id @default(uuid())
  userId         String  @unique
  specialization String?
  qualification  String?
  signatureUrl     String?
  consultationFee  Decimal? @db.Decimal(10, 2)
  experienceYears  Int?
  languages        String[]
  averageRating    Decimal? @db.Decimal(3, 2)
  subSpecialty     String?
  bio              String?

  tenantId         String?
  tenant           Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules            DoctorSchedule[]
  scheduleOverrides    ScheduleOverride[]
  appointments         Appointment[]
  prescriptions        Prescription[]
  consultations        Consultation[]
  admissions           Admission[]
  medicationOrders     MedicationOrder[]
  labOrders            LabOrder[]
  referralsFrom        Referral[]            @relation("ReferrerDoctor")
  referralsTo          Referral[]            @relation("RefereeDoctor")
  surgeriesLead        Surgery[]             @relation("LeadSurgeon")
  telemedicineSessions TelemedicineSession[]
  emergencyCases       EmergencyCase[]       @relation("EmergencyAttendingDoctor")
  ancCases             AntenatalCase[]
  waitlistEntries      WaitlistEntry[]
  controlledEntries    ControlledSubstanceEntry[]
  aiScribeSessions     AIScribeSession[]

  @@index([tenantId])
  @@map("doctors")
}

model DoctorSchedule {
  id                  String @id @default(uuid())
  doctorId            String
  dayOfWeek           Int // 0=Sunday, 6=Saturday
  startTime           String // HH:MM
  endTime             String // HH:MM
  slotDurationMinutes Int    @default(15)
  bufferMinutes       Int    @default(0) // minutes between slots

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek, startTime])
  @@map("doctor_schedules")
}

model ScheduleOverride {
  id        String   @id @default(uuid())
  doctorId  String
  date      DateTime @db.Date
  isBlocked Boolean  @default(true)
  startTime String? // HH:MM — if not blocked, override hours
  endTime   String?
  reason    String?

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date])
  @@map("schedule_overrides")
}

// ─── PATIENT ────────────────────────────────────────────

model Patient {
  id                    String    @id @default(uuid())
  userId                String    @unique
  mrNumber              String    @unique
  dateOfBirth           DateTime? @db.Date
  age                   Int?
  gender                Gender
  address               String?
  bloodGroup            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  insuranceProvider     String?
  insurancePolicyNumber String?
  maritalStatus         String?
  occupation            String?
  religion              String?
  preferredLanguage     String?
  abhaId                String?
  aadhaarMasked         String?
  photoUrl              String?
  mergedIntoId          String?
  // Family linking (Apr 2026)
  guardianPatientId    String?
  // No-show policy (Apr 2026)
  noShowCount           Int       @default(0)
  // Pricing tier (Apr 2026) — STANDARD, EMPLOYEE, SENIOR_CITIZEN, BPL, VIP
  pricingTier           String    @default("STANDARD")

  tenantId             String?
  tenant               Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guardian             Patient?              @relation("PatientGuardian", fields: [guardianPatientId], references: [id])
  dependents           Patient[]             @relation("PatientGuardian")
  familyLinks          PatientFamilyLink[]   @relation("PatientPrimary")
  familyLinkedBy       PatientFamilyLink[]   @relation("PatientRelated")
  appointments         Appointment[]
  vitals               Vitals[]
  prescriptions        Prescription[]
  invoices             Invoice[]
  insuranceClaims      InsuranceClaim[]
  admissions           Admission[]
  labOrders            LabOrder[]
  allergies            PatientAllergy[]
  chronicConditions    ChronicCondition[]
  familyHistory        FamilyHistory[]
  immunizations        Immunization[]
  documents            PatientDocument[]
  referralsFrom        Referral[]            @relation("PatientReferrals")
  surgeries            Surgery[]
  packagePurchases     PackagePurchase[]
  telemedicineSessions TelemedicineSession[]
  emergencyCases       EmergencyCase[]
  bloodRequests        BloodRequest[]
  ambulanceTrips       AmbulanceTrip[]
  ancCase              AntenatalCase?
  growthRecords        GrowthRecord[]
  feedbacks            PatientFeedback[]
  complaints           Complaint[]
  visitors             Visitor[]
  waitlistEntries      WaitlistEntry[]
  coordinatedVisits    CoordinatedVisit[]
  paymentPlans         PaymentPlan[]
  preAuthRequests      PreAuthRequest[]
  controlledEntries    ControlledSubstanceEntry[]
  advanceDirectives    AdvanceDirective[]
  medReconciliations   MedReconciliation[]
  milestoneRecords     MilestoneRecord[]
  feedingLogs          FeedingLog[]
  aiTriageSessions     AITriageSession[]
  aiScribeSessions     AIScribeSession[]
  abhaLinks            AbhaLink[]
  consentArtefacts     ConsentArtefact[]
  careContexts         CareContext[]
  insuranceClaimsV2    InsuranceClaim2[]
  doseLogs             AdherenceDoseLog[]

  @@index([mrNumber])
  @@index([tenantId])
  @@map("patients")
}

// ─── APPOINTMENTS & QUEUE ───────────────────────────────

model Appointment {
  id                    String            @id @default(uuid())
  patientId             String
  doctorId              String
  date                  DateTime          @db.Date
  slotStart             String? // HH:MM — null for walk-ins
  slotEnd               String?
  tokenNumber           Int
  type                  AppointmentType
  status                AppointmentStatus @default(BOOKED)
  priority              Priority          @default(NORMAL)
  notes                 String?
  checkInAt             DateTime?
  consultationStartedAt DateTime?
  consultationEndedAt   DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  // Group appointments (Apr 2026) — therapy / training sessions
  groupId               String?

  // Coordinated multi-doctor visit (Apr 2026)
  coordinatedVisitId    String?

  // LWBS (Left Without Being Seen) - reuses NO_SHOW status (Apr 2026)
  lwbsReason            String?

  tenantId              String?
  tenant                Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  patient           Patient           @relation(fields: [patientId], references: [id])
  doctor            Doctor            @relation(fields: [doctorId], references: [id])
  vitals            Vitals?
  consultation      Consultation?
  prescription      Prescription?
  invoice           Invoice?
  coordinatedVisit  CoordinatedVisit? @relation("CoordinatedAppointments", fields: [coordinatedVisitId], references: [id])
  aiTriageSession   AITriageSession?
  aiScribeSession   AIScribeSession?

  @@unique([doctorId, date, tokenNumber])
  @@index([doctorId, date])
  @@index([patientId])
  @@index([date, status])
  @@index([groupId])
  @@index([coordinatedVisitId])
  @@index([tenantId])
  @@map("appointments")
}

// ─── PATIENT FAMILY LINKS (bidirectional) ───────────────
model PatientFamilyLink {
  id               String   @id @default(uuid())
  patientId        String
  relatedPatientId String
  relationship     String // PARENT, CHILD, SPOUSE, SIBLING, GUARDIAN
  createdAt        DateTime @default(now())

  patient        Patient @relation("PatientPrimary", fields: [patientId], references: [id], onDelete: Cascade)
  relatedPatient Patient @relation("PatientRelated", fields: [relatedPatientId], references: [id], onDelete: Cascade)

  @@unique([patientId, relatedPatientId])
  @@index([patientId])
  @@index([relatedPatientId])
  @@map("patient_family_links")
}

// ─── OPD — VITALS & CONSULTATION ────────────────────────

model Vitals {
  id                     String   @id @default(uuid())
  appointmentId          String   @unique
  patientId              String
  nurseId                String
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  temperature            Float?
  temperatureUnit        String?  @default("F") // "F" or "C"
  weight                 Float?
  height                 Float?
  pulseRate              Int?
  spO2                   Int?
  painScale              Int? // 0-10
  respiratoryRate        Int?
  bmi                    Float?
  isAbnormal             Boolean  @default(false)
  abnormalFlags          String? // comma-separated flags e.g. "HIGH_BP,LOW_SPO2"
  notes                  String?
  recordedAt             DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     Patient     @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("vitals")
}

model Consultation {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  doctorId      String
  notes         String?
  findings      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])

  @@index([tenantId])
  @@map("consultations")
}

// ─── PRESCRIPTIONS ──────────────────────────────────────

model Prescription {
  id            String    @id @default(uuid())
  appointmentId String    @unique
  patientId     String
  doctorId      String
  diagnosis     String
  advice        String?
  followUpDate  DateTime? @db.Date
  signatureUrl  String?
  pdfUrl        String?
  printed       Boolean   @default(false)
  printedAt     DateTime?
  sharedVia     String? // WHATSAPP,EMAIL,SMS (comma-separated)
  sharedAt      DateTime?
  copiedFromId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  appointment Appointment        @relation(fields: [appointmentId], references: [id])
  patient     Patient            @relation(fields: [patientId], references: [id])
  doctor      Doctor             @relation(fields: [doctorId], references: [id])
  items       PrescriptionItem[]
  controlledEntries ControlledSubstanceEntry[]

  @@index([patientId])
  @@index([tenantId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String  @id @default(uuid())
  prescriptionId String
  medicineName   String
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  refills        Int     @default(0)
  refillsUsed    Int     @default(0)

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@map("prescription_items")
}

// ─── ICD-10 CODE DIRECTORY ──────────────────────────────
model Icd10Code {
  id          String   @id @default(uuid())
  code        String   @unique
  description String
  category    String?
  createdAt   DateTime @default(now())

  @@index([code])
  @@index([category])
  @@map("icd10_codes")
}

// ─── PRESCRIPTION TEMPLATES ─────────────────────────────
model PrescriptionTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  diagnosis String
  advice    String?
  specialty String?
  items     Json // Array<{medicineName,dosage,frequency,duration,instructions?}>
  createdBy String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("prescription_templates")
}

// ─── BILLING ────────────────────────────────────────────

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  appointmentId   String        @unique
  patientId       String
  subtotal        Float
  taxAmount       Float         @default(0)
  cgstAmount      Float         @default(0) // Central GST half of taxAmount
  sgstAmount      Float         @default(0) // State GST half
  packageDiscount Float         @default(0) // discount from active HealthPackage
  advanceApplied  Float         @default(0) // deposit applied to this invoice
  discountAmount  Float         @default(0)
  totalAmount     Float
  paymentStatus   PaymentStatus @default(PENDING)
  // Razorpay order id stored when /pay-online creates the order; used by
  // the webhook handler to look up the invoice in O(1).
  razorpayOrderId String?       @unique
  dueDate         DateTime?     @db.Date
  reminderSentAt  DateTime?
  // Late-fee automation (Apr 2026)
  lateFeeAmount    Float     @default(0)
  lateFeeAppliedAt DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenantId        String?
  tenant          Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  appointment       Appointment        @relation(fields: [appointmentId], references: [id])
  patient           Patient            @relation(fields: [patientId], references: [id])
  items             InvoiceItem[]
  payments          Payment[]
  insuranceClaims   InsuranceClaim[]
  insuranceClaimsV2 InsuranceClaim2[]
  paymentPlans      PaymentPlan[]
  discountApprovals DiscountApproval[]
  creditNotes     CreditNote[]

  @@index([patientId])
  @@index([invoiceNumber])
  @@index([tenantId])
  @@map("invoices")
}

model InvoiceItem {
  id          String @id @default(uuid())
  invoiceId   String
  description String
  category    String
  quantity    Int    @default(1)
  unitPrice   Float
  amount      Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id            String            @id @default(uuid())
  invoiceId     String
  amount        Float
  mode          PaymentMode
  // Provider transaction id (Razorpay payment_id, etc.) — unique to enforce
  // idempotency: replays of the same browser callback or webhook MUST NOT
  // create duplicate Payment rows.
  transactionId String?           @unique
  status        PaymentTxnStatus  @default(CAPTURED)
  paidAt        DateTime          @default(now())

  tenantId      String?
  tenant        Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([tenantId])
  @@map("payments")
}

model InsuranceClaim {
  id                String      @id @default(uuid())
  invoiceId         String
  patientId         String
  insuranceProvider String
  policyNumber      String
  claimAmount       Float
  approvedAmount    Float?
  status            ClaimStatus @default(SUBMITTED)
  submittedAt       DateTime    @default(now())
  resolvedAt        DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([invoiceId])
  @@index([patientId])
  @@map("insurance_claims")
}

// ─── NOTIFICATIONS ──────────────────────────────────────

model Notification {
  id             String                     @id @default(uuid())
  userId         String
  type           NotificationType
  channel        NotificationChannel
  title          String
  message        String
  data           Json?
  deliveryStatus NotificationDeliveryStatus @default(QUEUED)
  failureReason  String?
  deliveredAt    DateTime?
  scheduledFor   DateTime? // for deferred / quiet-hour respecting sends
  sentAt         DateTime?
  readAt         DateTime?
  createdAt      DateTime                   @default(now())

  tenantId       String?
  tenant         Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([deliveryStatus])
  @@index([tenantId])
  @@map("notifications")
}

model NotificationPreference {
  id      String              @id @default(uuid())
  userId  String
  channel NotificationChannel
  enabled Boolean             @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("notification_preferences")
}

// ─── AUDIT ──────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── SYSTEM ─────────────────────────────────────────────

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("system_config")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: IPD / INPATIENT MANAGEMENT
// ═══════════════════════════════════════════════════════

model Ward {
  id          String   @id @default(uuid())
  name        String   @unique
  type        WardType
  floor       String?
  description String?
  createdAt   DateTime @default(now())

  beds Bed[]

  @@map("wards")
}

model Bed {
  id        String    @id @default(uuid())
  wardId    String
  bedNumber String
  status    BedStatus @default(AVAILABLE)
  dailyRate Float     @default(0)
  notes     String?

  ward       Ward        @relation(fields: [wardId], references: [id])
  admissions Admission[]

  @@unique([wardId, bedNumber])
  @@index([status])
  @@map("beds")
}

model Admission {
  id                   String          @id @default(uuid())
  admissionNumber      String          @unique
  patientId            String
  doctorId             String
  bedId                String
  status               AdmissionStatus @default(ADMITTED)
  admittedAt           DateTime        @default(now())
  dischargedAt         DateTime?
  reason               String
  diagnosis            String?
  dischargeSummary     String?
  dischargeNotes       String?
  // Enhanced fields (Apr 2026)
  admissionType        AdmissionType?
  referredByDoctor     String? // external referring physician name
  finalDiagnosis       String?
  treatmentGiven       String?
  conditionAtDischarge String? // STABLE, IMPROVED, CRITICAL, UNCHANGED, DECEASED
  dischargeMedications String?
  followUpInstructions String?
  totalBillAmount      Float?          @default(0)
  // Isolation tracking (Apr 2026)
  isolationType        String? // STANDARD, CONTACT, DROPLET, AIRBORNE, REVERSE_ISOLATION
  isolationReason      String?
  isolationStartDate   DateTime?
  isolationEndDate     DateTime?
  // Expected LOS (Apr 2026)
  expectedLosDays      Int?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  tenantId             String?
  tenant               Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  patient          Patient            @relation(fields: [patientId], references: [id])
  doctor           Doctor             @relation(fields: [doctorId], references: [id])
  bed              Bed                @relation(fields: [bedId], references: [id])
  ipdVitals        IpdVitals[]
  medicationOrders MedicationOrder[]
  nurseRounds      NurseRound[]
  labOrders        LabOrder[]
  intakeOutputs    IpdIntakeOutput[]
  emergencyCases   EmergencyCase[]    @relation("EmergencyAdmission")
  belongings       PatientBelongings?

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([tenantId])
  @@map("admissions")
}

model IpdVitals {
  id                     String   @id @default(uuid())
  admissionId            String
  recordedBy             String // user id
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  temperature            Float?
  pulseRate              Int?
  respiratoryRate        Int?
  spO2                   Int?
  painScore              Int?
  bloodSugar             Int?
  notes                  String?
  recordedAt             DateTime @default(now())

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([admissionId, recordedAt])
  @@map("ipd_vitals")
}

model MedicationOrder {
  id           String    @id @default(uuid())
  admissionId  String
  doctorId     String
  medicineId   String? // link to medicine catalog
  medicineName String
  dosage       String
  frequency    String // e.g. "every 6 hours", "BID", "TID"
  route        String // oral, IV, IM, SC, topical
  startDate    DateTime  @default(now())
  endDate      DateTime?
  instructions String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  tenantId     String?
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  admission       Admission                  @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  doctor          Doctor                     @relation(fields: [doctorId], references: [id])
  medicine        Medicine?                  @relation(fields: [medicineId], references: [id])
  administrations MedicationAdministration[]

  @@index([admissionId])
  @@index([isActive])
  @@index([tenantId])
  @@map("medication_orders")
}

model MedicationAdministration {
  id                String           @id @default(uuid())
  medicationOrderId String
  scheduledAt       DateTime
  administeredAt    DateTime?
  administeredBy    String? // nurse user id
  status            MedicationStatus @default(SCHEDULED)
  notes             String?

  medicationOrder MedicationOrder @relation(fields: [medicationOrderId], references: [id], onDelete: Cascade)
  nurse           User?           @relation(fields: [administeredBy], references: [id])

  @@index([medicationOrderId])
  @@index([scheduledAt, status])
  @@map("medication_administrations")
}

model NurseRound {
  id          String   @id @default(uuid())
  admissionId String
  nurseId     String
  notes       String
  performedAt DateTime @default(now())

  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  nurse     User      @relation(fields: [nurseId], references: [id])

  @@index([admissionId])
  @@index([performedAt])
  @@index([tenantId])
  @@map("nurse_rounds")
}

model IpdIntakeOutput {
  id          String           @id @default(uuid())
  admissionId String
  type        IntakeOutputType
  amountMl    Int
  description String? // e.g. "Normal saline", "Ringer's lactate"
  recordedAt  DateTime         @default(now())
  recordedBy  String // nurse user id
  notes       String?

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([admissionId, recordedAt])
  @@map("ipd_intake_output")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: MEDICINE DATABASE & DRUG INTERACTIONS
// ═══════════════════════════════════════════════════════

model Medicine {
  id                   String   @id @default(uuid())
  name                 String   @unique
  genericName          String?
  brand                String?
  form                 String? // tablet, syrup, injection, etc.
  strength             String? // "500mg", "250mg/5ml"
  category             String? // antibiotic, analgesic, etc.
  description          String?
  sideEffects          String?
  contraindications    String?
  prescriptionRequired Boolean  @default(true)
  pregnancyCategory    String? // A, B, C, D, X
  isNarcotic           Boolean  @default(false)
  schedule             String? // H, H1, X, G
  pediatricDoseMgPerKg Float?
  maxDailyDoseMg       Float?
  // Controlled substance register (Apr 2026)
  scheduleClass        String? // H, H1, X, etc.
  requiresRegister     Boolean  @default(false)
  // Patient education leaflet (Apr 2026)
  patientInstructions  String? // markdown leaflet text
  // Renal dosing (Apr 2026)
  renalAdjustmentNotes    String?
  requiresRenalAdjustment Boolean @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  medicationOrders  MedicationOrder[]
  interactionsA     DrugInteraction[] @relation("DrugA")
  interactionsB     DrugInteraction[] @relation("DrugB")
  inventoryItems    InventoryItem[]
  controlledEntries ControlledSubstanceEntry[]

  @@index([name])
  @@index([category])
  @@map("medicines")
}

model DrugInteraction {
  id          String @id @default(uuid())
  drugAId     String
  drugBId     String
  severity    String // MILD, MODERATE, SEVERE, CONTRAINDICATED
  description String

  drugA Medicine @relation("DrugA", fields: [drugAId], references: [id], onDelete: Cascade)
  drugB Medicine @relation("DrugB", fields: [drugBId], references: [id], onDelete: Cascade)

  @@unique([drugAId, drugBId])
  @@map("drug_interactions")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: PHARMACY INVENTORY
// ═══════════════════════════════════════════════════════

model InventoryItem {
  id              String    @id @default(uuid())
  medicineId      String
  batchNumber     String
  quantity        Int // current stock
  unitCost        Float
  sellingPrice    Float
  expiryDate      DateTime  @db.Date
  supplier        String?
  reorderLevel    Int       @default(10)
  reorderQuantity Int? // suggested restock qty
  location        String? // shelf/rack location
  barcode         String? // EAN/UPC barcode
  recalled        Boolean   @default(false)
  recalledAt      DateTime?
  recallReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  medicine  Medicine         @relation(fields: [medicineId], references: [id])
  movements StockMovement[]
  returns   PharmacyReturn[]
  transfers StockTransfer[]

  @@unique([medicineId, batchNumber])
  @@index([expiryDate])
  @@index([barcode])
  @@map("inventory_items")
}

model StockMovement {
  id              String            @id @default(uuid())
  inventoryItemId String
  type            StockMovementType
  quantity        Int // positive for in, negative for out
  referenceId     String? // e.g., prescription id, purchase order id
  reason          String?
  performedBy     String // user id
  createdAt       DateTime          @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  user          User          @relation(fields: [performedBy], references: [id])

  @@index([inventoryItemId])
  @@index([createdAt])
  @@map("stock_movements")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: LAB TESTS
// ═══════════════════════════════════════════════════════

model LabTest {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., CBC, LFT
  name        String
  category    String? // Hematology, Biochemistry, Microbiology, etc.
  price       Float
  sampleType  String? // Blood, Urine, Stool
  normalRange String? // Free text for reference ranges
  unit        String? // default unit (mg/dL, g/L, etc.)
  panicLow    Float? // critical low threshold
  panicHigh   Float? // critical high threshold
  tatHours    Int? // expected turnaround time in hours
  description String?
  createdAt   DateTime @default(now())

  orderItems LabOrderItem[]
  ranges     LabTestReferenceRange[]
  qcEntries  LabQCEntry[]

  @@index([code])
  @@index([category])
  @@map("lab_tests")
}

model LabTestReferenceRange {
  id        String  @id @default(uuid())
  testId    String
  parameter String? // if test has sub-parameters (CBC: Hemoglobin etc.)
  gender    String? // MALE | FEMALE | null = any
  ageMin    Int? // in years, inclusive
  ageMax    Int? // in years, inclusive
  low       Float?
  high      Float?
  unit      String?
  notes     String?

  test LabTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@map("lab_test_reference_ranges")
}

model LabOrder {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  patientId       String
  doctorId        String
  admissionId     String? // null for OPD
  status          LabTestStatus @default(ORDERED)
  notes           String?
  orderedAt       DateTime      @default(now())
  collectedAt     DateTime?
  completedAt     DateTime?
  rejectedAt      DateTime?
  rejectionReason String? // INSUFFICIENT_SAMPLE, HEMOLYZED, CLOTTED, WRONG_LABEL, etc.
  // Priority routing (Apr 2026)
  priority        String        @default("ROUTINE") // ROUTINE, URGENT, STAT
  stat            Boolean       @default(false)

  tenantId        String?
  tenant          Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  patient   Patient        @relation(fields: [patientId], references: [id])
  doctor    Doctor         @relation(fields: [doctorId], references: [id])
  admission Admission?     @relation(fields: [admissionId], references: [id])
  items     LabOrderItem[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([tenantId])
  @@map("lab_orders")
}

model LabOrderItem {
  id      String        @id @default(uuid())
  orderId String
  testId  String
  status  LabTestStatus @default(ORDERED)
  results LabResult[]

  order LabOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  test  LabTest  @relation(fields: [testId], references: [id])

  @@map("lab_order_items")
}

model LabResult {
  id          String        @id @default(uuid())
  orderItemId String
  parameter   String // e.g., "Hemoglobin", "WBC Count"
  value       String
  unit        String?
  normalRange String?
  flag        LabResultFlag @default(NORMAL)
  notes       String?
  enteredBy   String // user id
  reportedAt  DateTime      @default(now())
  // Delta-check (Apr 2026) — significant change vs previous result
  deltaFlag   Boolean       @default(false)
  // Result verification workflow (Apr 2026)
  verifiedBy  String? // user id (doctor)
  verifiedAt  DateTime?

  tenantId    String?
  tenant      Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  orderItem LabOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([tenantId])
  @@map("lab_results")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: ELECTRONIC HEALTH RECORDS (EHR)
// ═══════════════════════════════════════════════════════

model PatientAllergy {
  id        String          @id @default(uuid())
  patientId String
  allergen  String
  severity  AllergySeverity @default(MILD)
  reaction  String?
  notes     String?
  notedBy   String // user id
  notedAt   DateTime        @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_allergies")
}

model ChronicCondition {
  id            String          @id @default(uuid())
  patientId     String
  condition     String
  icd10Code     String?
  diagnosedDate DateTime?       @db.Date
  status        ConditionStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("chronic_conditions")
}

model FamilyHistory {
  id        String  @id @default(uuid())
  patientId String
  relation  String // Mother, Father, Sibling, etc.
  condition String
  notes     String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("family_history")
}

model Immunization {
  id             String    @id @default(uuid())
  patientId      String
  vaccine        String
  doseNumber     Int?
  dateGiven      DateTime  @db.Date
  administeredBy String? // user id or external provider
  batchNumber    String?
  manufacturer   String?
  site           String? // left arm, etc.
  nextDueDate    DateTime? @db.Date
  notes          String?
  createdAt      DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([nextDueDate])
  @@map("immunizations")
}

model PatientDocument {
  id         String       @id @default(uuid())
  patientId  String
  type       DocumentType
  title      String
  filePath   String // server file path or URL
  fileSize   Int? // bytes
  mimeType   String?
  uploadedBy String // user id
  notes      String?
  createdAt  DateTime     @default(now())

  patient  Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploadedBy], references: [id])

  @@index([patientId])
  @@index([type])
  @@map("patient_documents")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: REFERRALS
// ═══════════════════════════════════════════════════════

model Referral {
  id               String         @id @default(uuid())
  referralNumber   String         @unique
  patientId        String
  fromDoctorId     String
  toDoctorId       String? // null if external
  externalProvider String? // external hospital/specialist name
  externalContact  String?
  specialty        String?
  reason           String
  notes            String?
  status           ReferralStatus @default(PENDING)
  referredAt       DateTime       @default(now())
  respondedAt      DateTime?

  tenantId         String?
  tenant           Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  patient    Patient @relation("PatientReferrals", fields: [patientId], references: [id])
  fromDoctor Doctor  @relation("ReferrerDoctor", fields: [fromDoctorId], references: [id])
  toDoctor   Doctor? @relation("RefereeDoctor", fields: [toDoctorId], references: [id])

  @@index([patientId])
  @@index([fromDoctorId])
  @@index([status])
  @@index([tenantId])
  @@map("referrals")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: SURGERY / OPERATION THEATER
// ═══════════════════════════════════════════════════════

model OperatingTheater {
  id        String  @id @default(uuid())
  name      String  @unique
  floor     String?
  equipment String?
  dailyRate Float   @default(0)
  isActive  Boolean @default(true)

  surgeries Surgery[]

  @@map("operating_theaters")
}

model Surgery {
  id                   String        @id @default(uuid())
  caseNumber           String        @unique
  patientId            String
  surgeonId            String
  otId                 String
  procedure            String
  scheduledAt          DateTime
  durationMin          Int? // estimated duration
  actualStartAt        DateTime?
  actualEndAt          DateTime?
  status               SurgeryStatus @default(SCHEDULED)
  anaesthesiologist    String?
  assistants           String? // comma-separated names or JSON
  preOpNotes           String?
  postOpNotes          String?
  diagnosis            String?
  cost                 Float?        @default(0)
  // Pre-op checklist (Apr 2026)
  consentSigned        Boolean       @default(false)
  consentSignedAt      DateTime?
  npoSince             DateTime? // Nil Per Oral start time
  allergiesVerified    Boolean       @default(false)
  antibioticsGiven     Boolean       @default(false)
  antibioticsAt        DateTime?
  siteMarked           Boolean       @default(false)
  bloodReserved        Boolean       @default(false)
  preOpChecklistBy     String?
  // Intra-op timing
  anesthesiaStartAt    DateTime?
  anesthesiaEndAt      DateTime?
  incisionAt           DateTime?
  closureAt            DateTime?
  // Complications
  complications        String? // JSON/text — "bleeding", "hypotension", etc.
  complicationSeverity String? // MILD, MODERATE, SEVERE
  bloodLossMl          Int?
  // Turnaround tracking (Apr 2026)
  previousSurgeryId    String?
  // Post-op checklist (Apr 2026)
  sponge_countCorrect  Boolean?
  instrumentCountCorrect Boolean?
  specimenLabeled      Boolean?
  patientStable        Boolean?
  postOpChecklistBy    String?
  // SSI tracking (Apr 2026)
  ssiDetected          Boolean       @default(false)
  ssiType              String? // SUPERFICIAL, DEEP, ORGAN_SPACE
  ssiDetectedDate      DateTime?
  ssiTreatment         String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  tenantId             String?
  tenant               Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  patient Patient          @relation(fields: [patientId], references: [id])
  surgeon Doctor           @relation("LeadSurgeon", fields: [surgeonId], references: [id])
  ot      OperatingTheater @relation(fields: [otId], references: [id])

  anesthesiaRecord   AnesthesiaRecord?
  postOpObservations PostOpObservation[]

  @@index([patientId])
  @@index([surgeonId])
  @@index([scheduledAt])
  @@index([status])
  @@index([tenantId])
  @@map("surgeries")
}

model AnesthesiaRecord {
  id             String   @id @default(uuid())
  surgeryId      String   @unique
  anesthetist    String?
  anesthesiaType String // GENERAL, SPINAL, EPIDURAL, LOCAL, REGIONAL, SEDATION
  inductionAt    DateTime?
  extubationAt   DateTime?
  agents         Json? // [{ name, dose, time }]
  vitalsLog      Json? // [{ time, bp, hr, spo2, etco2 }]
  ivFluids       Json? // [{ fluid, volume, time }]
  bloodLossMl    Int?
  urineOutputMl  Int?
  complications  String?
  recoveryNotes  String?
  performedBy    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  surgery Surgery @relation(fields: [surgeryId], references: [id], onDelete: Cascade)

  @@map("anesthesia_records")
}

model PostOpObservation {
  id            String   @id @default(uuid())
  surgeryId     String
  observedAt    DateTime @default(now())
  bpSystolic    Int?
  bpDiastolic   Int?
  pulse         Int?
  spO2          Int?
  painScore     Int?
  consciousness String? // ALERT, DROWSY, UNRESPONSIVE
  nausea        Boolean  @default(false)
  notes         String?
  observedBy    String

  surgery Surgery @relation(fields: [surgeryId], references: [id], onDelete: Cascade)

  @@index([surgeryId, observedAt])
  @@map("post_op_observations")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: STAFF HR (SHIFTS & LEAVE)
// ═══════════════════════════════════════════════════════

model StaffShift {
  id        String      @id @default(uuid())
  userId    String
  date      DateTime    @db.Date
  type      ShiftType
  startTime String // HH:MM
  endTime   String
  status    ShiftStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime    @default(now())

  tenantId  String?
  tenant    Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
  @@index([date])
  @@index([status])
  @@index([tenantId])
  @@map("staff_shifts")
}

model LeaveRequest {
  id              String      @id @default(uuid())
  userId          String
  type            LeaveType
  fromDate        DateTime    @db.Date
  toDate          DateTime    @db.Date
  totalDays       Int
  reason          String
  status          LeaveStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenantId        String?
  tenant          Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  user     User  @relation("LeaveOwner", fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("LeaveApprover", fields: [approvedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@index([tenantId])
  @@map("leave_requests")
}

// ═══════════════════════════════════════════════════════
// PHASE 3: FINANCE EXPANSION
// ═══════════════════════════════════════════════════════

model HealthPackage {
  id               String   @id @default(uuid())
  name             String
  description      String?
  services         String // comma-separated list or JSON
  price            Float
  discountPrice    Float?
  validityDays     Int      @default(365)
  category         String?
  maxFamilyMembers Int      @default(1) // family package support
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchases PackagePurchase[]

  @@index([category])
  @@map("health_packages")
}

model PackagePurchase {
  id              String    @id @default(uuid())
  purchaseNumber  String    @unique
  packageId       String
  patientId       String // primary holder
  familyMemberIds String? // comma-separated patient IDs covered
  purchasedAt     DateTime  @default(now())
  expiresAt       DateTime
  amountPaid      Float
  servicesUsed    String? // JSON array of { service, patientId, usedAt, appointmentId? }
  renewedFromId   String? // prior purchase that was renewed
  reminderSentAt  DateTime?
  isFullyUsed     Boolean   @default(false)

  package HealthPackage @relation(fields: [packageId], references: [id])
  patient Patient       @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([packageId])
  @@index([expiresAt])
  @@map("package_purchases")
}

model Supplier {
  id                String    @id @default(uuid())
  name              String    @unique
  contactPerson     String?
  phone             String?
  email             String?
  address           String?
  gstNumber         String?
  paymentTerms      String?
  contractStart     DateTime? @db.Date
  contractEnd       DateTime? @db.Date
  rating            Float? // 0-5 performance rating
  onTimeDeliveries  Int       @default(0)
  lateDeliveries    Int       @default(0)
  outstandingAmount Float     @default(0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())

  purchaseOrders PurchaseOrder[]
  payments       SupplierPayment[]

  @@map("suppliers")
}

model PurchaseOrder {
  id                 String              @id @default(uuid())
  poNumber           String              @unique
  supplierId         String
  status             PurchaseOrderStatus @default(DRAFT)
  orderedAt          DateTime            @default(now())
  expectedAt         DateTime?
  receivedAt         DateTime?
  subtotal           Float
  taxAmount          Float               @default(0)
  totalAmount        Float
  invoiceAmount      Float?
  invoiceNumber      String?
  notes              String?
  createdBy          String?
  approvedBy         String?
  isRecurring        Boolean             @default(false)
  recurringFrequency RecurringFrequency?
  parentPoId         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]
  grns     Grn[]

  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String  @id @default(uuid())
  poId        String
  description String // item name/description
  medicineId  String?
  quantity    Int
  unitPrice   Float
  amount      Float

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
  @@map("purchase_order_items")
}

model Expense {
  id                 String              @id @default(uuid())
  category           ExpenseCategory
  amount             Float
  description        String
  date               DateTime            @db.Date
  paidTo             String?
  paidBy             String
  referenceNo        String?
  attachmentPath     String?
  approvalStatus     ApprovalStatus      @default(APPROVED) // > threshold set to PENDING
  approvedBy         String?
  approvedAt         DateTime?
  rejectionReason    String?
  isRecurring        Boolean             @default(false)
  recurringFrequency RecurringFrequency?
  parentExpenseId    String? // for auto-generated recurring
  createdAt          DateTime            @default(now())

  user User @relation(fields: [paidBy], references: [id])

  @@index([date])
  @@index([category])
  @@index([approvalStatus])
  @@map("expenses")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: TELEMEDICINE
// ═══════════════════════════════════════════════════════

model TelemedicineSession {
  id                  String             @id @default(uuid())
  sessionNumber       String             @unique
  patientId           String
  doctorId            String
  scheduledAt         DateTime
  startedAt           DateTime?
  endedAt             DateTime?
  durationMin         Int?
  meetingUrl          String?
  meetingId           String?
  status              TelemedicineStatus @default(SCHEDULED)
  chiefComplaint      String?
  doctorNotes         String?
  patientRating       Int? // 1-5
  prescriptionId      String?
  fee                 Float              @default(500)
  // Enhancements (Apr 2026)
  preConsultQuestions String? // JSON pre-consultation questionnaire
  technicalIssues     String? // e.g. "AUDIO_DROP,CONNECTION_LOST"
  recordingConsent    Boolean            @default(false)
  recordingUrl        String?
  followUpScheduledAt DateTime?
  patientJoinedAt     DateTime? // waiting room
  // Chat during session (Apr 2026)
  sessionMessages     Json? // Array<{id,sender,text,sentAt}>
  // ─── Waiting room / admit flow (Apr 2026) ────────────
  /// "IDLE" | "PATIENT_WAITING" | "ADMITTED" | "DENIED"
  waitingRoomState    String?            @default("IDLE")
  admittedAt          DateTime?
  deniedAt            DateTime?
  denyReason          String?
  // ─── Pre-check (camera / mic self-test) ──────────────
  precheckPassed      Boolean            @default(false)
  precheckAt          DateTime?
  precheckDetails     Json? // { camera, mic, bandwidthKbps?, userAgent? }
  // ─── Recording metadata (Jibri) ──────────────────────
  recordingStartedAt  DateTime?
  recordingStoppedAt  DateTime?
  /// Room name used for this session (matches Jitsi room slug).
  jitsiRoom           String?
  // ─── Screen-share audit ──────────────────────────────
  screenShareEvents   Json? // Array<{ action: 'START'|'STOP', by: userId, at: ISO }>
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  tenantId            String?
  tenant              Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@index([tenantId])
  @@map("telemedicine_sessions")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: EMERGENCY / TRIAGE
// ═══════════════════════════════════════════════════════

model EmergencyCase {
  id                String          @id @default(uuid())
  caseNumber        String          @unique
  patientId         String? // null if unknown/unregistered
  unknownName       String? // for Jane/John Does
  unknownAge        Int?
  unknownGender     String?
  arrivedAt         DateTime        @default(now())
  arrivalMode       String? // Walk-in, Ambulance, Police, Referred
  triageLevel       TriageLevel?
  triagedAt         DateTime?
  triagedBy         String? // user id
  chiefComplaint    String
  mewsScore         Int? // Modified Early Warning Score (0-14)
  vitalsBP          String?
  vitalsPulse       Int?
  vitalsResp        Int?
  vitalsSpO2        Int?
  vitalsTemp        Float?
  glasgowComa       Int? // GCS 3-15
  attendingDoctorId String?
  seenAt            DateTime?
  status            EmergencyStatus @default(WAITING)
  disposition       String? // admit, discharge, transfer, dama
  outcomeNotes      String?
  closedAt          DateTime?
  // MLC / Police case (Apr 2026)
  isMLC             Boolean         @default(false)
  mlcNumber         String?
  mlcPoliceStation  String?
  mlcFIRNumber      String?
  mlcOfficerName    String?
  // ER-to-admission link
  linkedAdmissionId String?
  // Repeat visit (<72h) — cached at registration
  isRepeatVisit     Boolean         @default(false)
  treatmentOrders   String? // JSON list of meds/procedures given in ER
  // Revised Trauma Score (Apr 2026)
  rtsRespiratory    Int? // coded 0-4
  rtsSystolic       Int? // coded 0-4
  rtsGCS            Int? // coded 0-4
  rtsScore          Float?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenantId          String?
  tenant            Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  patient         Patient?   @relation(fields: [patientId], references: [id])
  attendingDoctor Doctor?    @relation("EmergencyAttendingDoctor", fields: [attendingDoctorId], references: [id])
  linkedAdmission Admission? @relation("EmergencyAdmission", fields: [linkedAdmissionId], references: [id])

  @@index([status])
  @@index([triageLevel])
  @@index([arrivedAt])
  @@index([isMLC])
  @@index([tenantId])
  @@map("emergency_cases")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: BLOOD BANK
// ═══════════════════════════════════════════════════════

model BloodDonor {
  id             String         @id @default(uuid())
  donorNumber    String         @unique
  name           String
  phone          String
  email          String?
  bloodGroup     BloodGroupType
  dateOfBirth    DateTime?      @db.Date
  gender         Gender
  weight         Float?
  address        String?
  lastDonation   DateTime?      @db.Date
  totalDonations Int            @default(0)
  isEligible     Boolean        @default(true)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  donations BloodDonation[]
  deferrals DonorDeferral[]

  @@index([bloodGroup])
  @@index([phone])
  @@map("blood_donors")
}

model BloodDonation {
  id             String   @id @default(uuid())
  donorId        String
  donatedAt      DateTime @default(now())
  volumeMl       Int      @default(450)
  unitNumber     String   @unique
  screeningNotes String?
  approved       Boolean  @default(false)
  approvedBy     String?
  hemoglobinGdL  Float?
  bloodPressure  String?
  createdAt      DateTime @default(now())

  donor      BloodDonor           @relation(fields: [donorId], references: [id])
  units      BloodUnit[]
  screening  BloodScreening?
  separations ComponentSeparation[]

  @@index([donorId])
  @@map("blood_donations")
}

model BloodScreening {
  id             String   @id @default(uuid())
  donationId     String   @unique
  hivResult      String // NEGATIVE, POSITIVE, INDETERMINATE
  hcvResult      String
  hbsAgResult    String
  syphilisResult String
  malariaResult  String
  bloodGrouping  String? // ABO confirmation
  method         String? // ELISA, Rapid, NAT
  screenedBy     String // user id
  screenedAt     DateTime @default(now())
  notes          String?
  passed         Boolean // overall pass/fail

  donation BloodDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([passed])
  @@map("blood_screenings")
}

model BloodTemperatureLog {
  id          String   @id @default(uuid())
  location    String // e.g., "Fridge A", "Freezer Plasma-1"
  temperature Float // Celsius
  recordedAt  DateTime @default(now())
  recordedBy  String // user id
  inRange     Boolean  @default(true)
  notes       String?

  @@index([location, recordedAt])
  @@map("blood_temperature_logs")
}

model BloodCrossMatch {
  id          String   @id @default(uuid())
  requestId   String
  unitId      String
  compatible  Boolean
  method      String?
  performedBy String
  performedAt DateTime @default(now())
  notes       String?

  @@index([requestId])
  @@index([unitId])
  @@map("blood_cross_matches")
}

model BloodUnit {
  id              String          @id @default(uuid())
  unitNumber      String          @unique
  donationId      String?
  bloodGroup      BloodGroupType
  component       BloodComponent
  volumeMl        Int
  collectedAt     DateTime
  expiresAt       DateTime
  status          BloodUnitStatus @default(AVAILABLE)
  storageLocation String?
  notes           String?
  // Reservation (Apr 2026)
  reservedUntil       DateTime?
  reservedForRequestId String?
  reservedBy          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  donation BloodDonation? @relation(fields: [donationId], references: [id])
  requests BloodRequest[]

  @@index([bloodGroup, component, status])
  @@index([expiresAt])
  @@map("blood_units")
}

model BloodRequest {
  id             String         @id @default(uuid())
  requestNumber  String         @unique
  patientId      String
  bloodGroup     BloodGroupType
  component      BloodComponent
  unitsRequested Int
  reason         String
  urgency        String // ROUTINE, URGENT, EMERGENCY
  requestedBy    String // user id
  issuedAt       DateTime?
  issuedBy       String?
  fulfilled      Boolean        @default(false)
  notes          String?
  createdAt      DateTime       @default(now())

  patient Patient     @relation(fields: [patientId], references: [id])
  units   BloodUnit[]

  @@index([patientId])
  @@index([fulfilled])
  @@map("blood_requests")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: AMBULANCE MANAGEMENT
// ═══════════════════════════════════════════════════════

model Ambulance {
  id              String          @id @default(uuid())
  vehicleNumber   String          @unique
  make            String?
  model           String?
  type            String
  status          AmbulanceStatus @default(AVAILABLE)
  driverName      String?
  driverPhone     String?
  paramedicName   String?
  lastServiceDate DateTime?       @db.Date
  nextServiceDate DateTime?       @db.Date
  fuelLevel       Float? // percent 0-100
  notes           String?
  createdAt       DateTime        @default(now())

  trips    AmbulanceTrip[]
  fuelLogs AmbulanceFuelLog[]

  @@map("ambulances")
}

model AmbulanceFuelLog {
  id          String   @id @default(uuid())
  ambulanceId String
  litres      Float
  costTotal   Float
  odometerKm  Int?
  stationName String?
  filledAt    DateTime @default(now())
  filledBy    String // user id
  notes       String?

  ambulance Ambulance @relation(fields: [ambulanceId], references: [id], onDelete: Cascade)

  @@index([ambulanceId, filledAt])
  @@map("ambulance_fuel_logs")
}

model AmbulanceTrip {
  id               String              @id @default(uuid())
  tripNumber       String              @unique
  ambulanceId      String
  patientId        String?
  callerName       String?
  callerPhone      String?
  pickupAddress    String
  pickupLat        Float?
  pickupLng        Float?
  dropAddress      String?
  dropLat          Float?
  dropLng          Float?
  distanceKm       Float?
  chiefComplaint   String?
  priority         String? // RED | YELLOW | GREEN
  equipmentChecked Boolean             @default(false)
  equipmentNotes   String?
  requestedAt      DateTime            @default(now())
  dispatchedAt     DateTime?
  arrivedAt        DateTime?
  completedAt      DateTime?
  status           AmbulanceTripStatus @default(REQUESTED)
  cost             Float?
  invoiceId        String?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  ambulance Ambulance @relation(fields: [ambulanceId], references: [id])
  patient   Patient?  @relation(fields: [patientId], references: [id])

  @@index([ambulanceId])
  @@index([status])
  @@index([priority])
  @@index([requestedAt])
  @@map("ambulance_trips")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: ASSET MANAGEMENT
// ═══════════════════════════════════════════════════════

model Asset {
  id                  String      @id @default(uuid())
  assetTag            String      @unique
  name                String
  category            String
  manufacturer        String?
  modelNumber         String?
  serialNumber        String?
  purchaseDate        DateTime?   @db.Date
  purchaseCost        Float?
  salvageValue        Float?      @default(0)
  usefulLifeYears     Int?
  depreciationMethod  String?     @default("STRAIGHT_LINE")
  warrantyExpiry      DateTime?   @db.Date
  location            String?
  department          String?
  status              AssetStatus @default(IDLE)
  amcProvider         String?
  amcExpiryDate       DateTime?   @db.Date
  calibrationInterval Int?
  lastCalibrationAt   DateTime?   @db.Date
  nextCalibrationAt   DateTime?   @db.Date
  disposedAt          DateTime?
  disposalMethod      String?
  disposalValue       Float?
  disposalNotes       String?
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  assignments AssetAssignment[]
  maintenance AssetMaintenance[]
  transfers   AssetTransfer[]

  @@index([category])
  @@index([status])
  @@index([nextCalibrationAt])
  @@map("assets")
}

model AssetTransfer {
  id             String   @id @default(uuid())
  assetId        String
  fromDepartment String?
  toDepartment   String
  fromLocation   String?
  toLocation     String?
  transferredBy  String
  transferredAt  DateTime @default(now())
  reason         String?
  notes          String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_transfers")
}

model AssetAssignment {
  id         String    @id @default(uuid())
  assetId    String
  assignedTo String // user id
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  location   String?
  notes      String?

  asset    Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assignee User  @relation(fields: [assignedTo], references: [id])

  @@index([assetId])
  @@index([assignedTo])
  @@map("asset_assignments")
}

model AssetMaintenance {
  id          String          @id @default(uuid())
  assetId     String
  type        MaintenanceType
  performedAt DateTime        @default(now())
  performedBy String // user id
  vendor      String?
  cost        Float?          @default(0)
  description String
  nextDueDate DateTime?       @db.Date
  createdAt   DateTime        @default(now())

  asset      Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  technician User  @relation(fields: [performedBy], references: [id])

  @@index([assetId])
  @@index([nextDueDate])
  @@map("asset_maintenance")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: MATERNITY / ANTENATAL CARE
// ═══════════════════════════════════════════════════════

model AntenatalCase {
  id           String    @id @default(uuid())
  caseNumber   String    @unique
  patientId    String    @unique // one active ANC case per patient
  doctorId     String
  lmpDate      DateTime  @db.Date // Last Menstrual Period
  eddDate      DateTime  @db.Date // Expected Delivery Date
  gravida      Int       @default(1)
  parity       Int       @default(0)
  bloodGroup   String?
  isHighRisk   Boolean   @default(false)
  riskFactors  String?
  deliveredAt  DateTime?
  deliveryType String? // NORMAL, C_SECTION, INSTRUMENTAL
  babyGender   String?
  babyWeight   Float?
  outcomeNotes String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient         Patient            @relation(fields: [patientId], references: [id])
  doctor          Doctor             @relation(fields: [doctorId], references: [id])
  visits          AncVisit[]
  ultrasounds     UltrasoundRecord[]
  partographs     Partograph[]
  postnatalVisits PostnatalVisit[]

  @@map("antenatal_cases")
}

model AncVisit {
  id               String       @id @default(uuid())
  ancCaseId        String
  type             AncVisitType
  visitDate        DateTime     @default(now())
  weeksOfGestation Int?
  weight           Float?
  bloodPressure    String?
  fundalHeight     String? // cm
  fetalHeartRate   Int?
  presentation     String?
  hemoglobin       Float?
  urineProtein     String?
  urineSugar       String?
  notes            String?
  prescribedMeds   String?
  nextVisitDate    DateTime?    @db.Date
  createdAt        DateTime     @default(now())

  ancCase AntenatalCase @relation(fields: [ancCaseId], references: [id], onDelete: Cascade)

  @@index([ancCaseId])
  @@map("anc_visits")
}

model UltrasoundRecord {
  id               String   @id @default(uuid())
  ancCaseId        String
  scanDate         DateTime @default(now())
  gestationalWeeks Int?
  efwGrams         Int?
  afi              Float?
  placentaPosition String?
  fetalHeartRate   Int?
  presentation     String?
  findings         String?
  impression       String?
  recordedBy       String
  createdAt        DateTime @default(now())

  ancCase AntenatalCase @relation(fields: [ancCaseId], references: [id], onDelete: Cascade)

  @@index([ancCaseId, scanDate])
  @@map("ultrasound_records")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: PEDIATRIC GROWTH
// ═══════════════════════════════════════════════════════

model GrowthRecord {
  id                 String   @id @default(uuid())
  patientId          String
  measurementDate    DateTime @default(now()) @db.Date
  ageMonths          Int
  weightKg           Float?
  heightCm           Float?
  headCircumference  Float? // cm
  bmi                Float?
  weightPercentile   Float? // 0-100
  heightPercentile   Float?
  milestoneNotes     String?
  developmentalNotes String?
  recordedBy         String
  createdAt          DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, measurementDate])
  @@map("growth_records")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: PATIENT FEEDBACK & COMPLAINTS
// ═══════════════════════════════════════════════════════

model PatientFeedback {
  id             String           @id @default(uuid())
  patientId      String
  category       FeedbackCategory
  rating         Int
  nps            Int?
  comment        String?
  sentiment      SentimentLabel? // derived from comment content
  sentimentScore Float? // -1..+1
  requestedVia   String? // SMS, EMAIL, WALK_IN
  submittedAt    DateTime         @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([category])
  @@index([submittedAt])
  @@index([sentiment])
  @@map("patient_feedback")
}

model Complaint {
  id               String          @id @default(uuid())
  ticketNumber     String          @unique
  patientId        String?
  name             String?
  phone            String?
  category         String
  subCategory      String?
  description      String
  status           ComplaintStatus @default(OPEN)
  assignedTo       String?
  resolution       String?
  resolvedAt       DateTime?
  slaDueAt         DateTime?
  escalatedAt      DateTime?
  escalationReason String?
  priority         String          @default("MEDIUM")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  patient Patient? @relation(fields: [patientId], references: [id])

  @@index([status])
  @@index([assignedTo])
  @@index([slaDueAt])
  @@map("complaints")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: INTERNAL CHAT / MESSAGING
// ═══════════════════════════════════════════════════════

model ChatRoom {
  id            String    @id @default(uuid())
  name          String?
  isGroup       Boolean   @default(false)
  isChannel     Boolean   @default(false) // department-wide broadcast channel
  department    String? // e.g. "Doctors", "Nursing", "All Staff"
  createdBy     String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([department])
  @@map("chat_rooms")
}

model ChatParticipant {
  id         String    @id @default(uuid())
  roomId     String
  userId     String
  joinedAt   DateTime  @default(now())
  leftAt     DateTime?
  lastReadAt DateTime?

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model ChatMessage {
  id              String      @id @default(uuid())
  roomId          String
  senderId        String
  type            MessageType @default(TEXT)
  content         String
  attachmentUrl   String?
  reactions       Json? // { "👍": [userId,...], "❤️": [userId,...] }
  mentionIds      String? // comma-separated userIds from @mentions
  isPinned        Boolean     @default(false)
  pinnedAt        DateTime?
  pinnedBy        String?
  parentMessageId String? // for threading/replies
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("MessageSender", fields: [senderId], references: [id])

  @@index([roomId, createdAt])
  @@index([senderId])
  @@index([isPinned])
  @@map("chat_messages")
}

// ═══════════════════════════════════════════════════════
// PHASE 4: VISITOR MANAGEMENT
// ═══════════════════════════════════════════════════════

model Visitor {
  id            String         @id @default(uuid())
  passNumber    String         @unique
  name          String
  phone         String?
  idProofType   String?
  idProofNumber String?
  photoUrl      String?
  patientId     String?
  purpose       VisitorPurpose
