generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum Role {
  ADMIN
  DOCTOR
  RECEPTION
  NURSE
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  BOOKED
  CHECKED_IN
  IN_CONSULTATION
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  SCHEDULED
  WALK_IN
}

enum Priority {
  NORMAL
  URGENT
  EMERGENCY
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
}

enum PaymentMode {
  CASH
  CARD
  UPI
  ONLINE
  INSURANCE
}

enum ClaimStatus {
  SUBMITTED
  APPROVED
  REJECTED
  SETTLED
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
}

enum NotificationType {
  APPOINTMENT_BOOKED
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLED
  TOKEN_CALLED
  PRESCRIPTION_READY
  BILL_GENERATED
  PAYMENT_RECEIVED
  SCHEDULE_SUMMARY
  ADMISSION
  DISCHARGE
  LAB_RESULT_READY
  MEDICATION_DUE
  LOW_STOCK_ALERT
}

// ─── PHASE 2 ENUMS ──────────────────────────────────────

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
  TRANSFERRED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
  RESERVED
}

enum WardType {
  GENERAL
  PRIVATE
  SEMI_PRIVATE
  ICU
  NICU
  HDU
  EMERGENCY
  MATERNITY
}

enum MedicationStatus {
  SCHEDULED
  ADMINISTERED
  MISSED
  REFUSED
  HELD
}

enum LabTestStatus {
  ORDERED
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LabResultFlag {
  NORMAL
  LOW
  HIGH
  CRITICAL
}

enum StockMovementType {
  PURCHASE
  DISPENSED
  RETURNED
  EXPIRED
  ADJUSTMENT
  DAMAGED
}

// ─── USERS & AUTH ───────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String
  name         String
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  doctor                    Doctor?
  patient                   Patient?
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  refreshTokens             RefreshToken[]
  medicationAdministrations MedicationAdministration[]
  nurseRounds               NurseRound[]
  stockMovements            StockMovement[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── DOCTOR ─────────────────────────────────────────────

model Doctor {
  id             String  @id @default(uuid())
  userId         String  @unique
  specialization String?
  qualification  String?
  signatureUrl   String?

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules         DoctorSchedule[]
  scheduleOverrides ScheduleOverride[]
  appointments      Appointment[]
  prescriptions     Prescription[]
  consultations     Consultation[]
  admissions        Admission[]
  medicationOrders  MedicationOrder[]
  labOrders         LabOrder[]

  @@map("doctors")
}

model DoctorSchedule {
  id                  String @id @default(uuid())
  doctorId            String
  dayOfWeek           Int // 0=Sunday, 6=Saturday
  startTime           String // HH:MM
  endTime             String // HH:MM
  slotDurationMinutes Int    @default(15)

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek, startTime])
  @@map("doctor_schedules")
}

model ScheduleOverride {
  id        String   @id @default(uuid())
  doctorId  String
  date      DateTime @db.Date
  isBlocked Boolean  @default(true)
  startTime String? // HH:MM — if not blocked, override hours
  endTime   String?
  reason    String?

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date])
  @@map("schedule_overrides")
}

// ─── PATIENT ────────────────────────────────────────────

model Patient {
  id                    String    @id @default(uuid())
  userId                String    @unique
  mrNumber              String    @unique
  dateOfBirth           DateTime? @db.Date
  age                   Int?
  gender                Gender
  address               String?
  bloodGroup            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  insuranceProvider     String?
  insurancePolicyNumber String?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  vitals          Vitals[]
  prescriptions   Prescription[]
  invoices        Invoice[]
  insuranceClaims InsuranceClaim[]
  admissions      Admission[]
  labOrders       LabOrder[]

  @@index([mrNumber])
  @@map("patients")
}

// ─── APPOINTMENTS & QUEUE ───────────────────────────────

model Appointment {
  id          String            @id @default(uuid())
  patientId   String
  doctorId    String
  date        DateTime          @db.Date
  slotStart   String? // HH:MM — null for walk-ins
  slotEnd     String?
  tokenNumber Int
  type        AppointmentType
  status      AppointmentStatus @default(BOOKED)
  priority    Priority          @default(NORMAL)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  vitals       Vitals?
  consultation Consultation?
  prescription Prescription?
  invoice      Invoice?

  @@unique([doctorId, date, tokenNumber])
  @@index([doctorId, date])
  @@index([patientId])
  @@index([date, status])
  @@map("appointments")
}

// ─── OPD — VITALS & CONSULTATION ────────────────────────

model Vitals {
  id                     String   @id @default(uuid())
  appointmentId          String   @unique
  patientId              String
  nurseId                String
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  temperature            Float?
  weight                 Float?
  height                 Float?
  pulseRate              Int?
  spO2                   Int?
  notes                  String?
  recordedAt             DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     Patient     @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("vitals")
}

model Consultation {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  doctorId      String
  notes         String?
  findings      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])

  @@map("consultations")
}

// ─── PRESCRIPTIONS ──────────────────────────────────────

model Prescription {
  id            String    @id @default(uuid())
  appointmentId String    @unique
  patientId     String
  doctorId      String
  diagnosis     String
  advice        String?
  followUpDate  DateTime? @db.Date
  signatureUrl  String?
  pdfUrl        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment Appointment        @relation(fields: [appointmentId], references: [id])
  patient     Patient            @relation(fields: [patientId], references: [id])
  doctor      Doctor             @relation(fields: [doctorId], references: [id])
  items       PrescriptionItem[]

  @@index([patientId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String  @id @default(uuid())
  prescriptionId String
  medicineName   String
  dosage         String
  frequency      String
  duration       String
  instructions   String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@map("prescription_items")
}

// ─── BILLING ────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  appointmentId  String        @unique
  patientId      String
  subtotal       Float
  taxAmount      Float         @default(0)
  discountAmount Float         @default(0)
  totalAmount    Float
  paymentStatus  PaymentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  appointment     Appointment      @relation(fields: [appointmentId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])
  items           InvoiceItem[]
  payments        Payment[]
  insuranceClaims InsuranceClaim[]

  @@index([patientId])
  @@index([invoiceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id          String @id @default(uuid())
  invoiceId   String
  description String
  category    String
  quantity    Int    @default(1)
  unitPrice   Float
  amount      Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id            String      @id @default(uuid())
  invoiceId     String
  amount        Float
  mode          PaymentMode
  transactionId String?
  paidAt        DateTime    @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model InsuranceClaim {
  id                String      @id @default(uuid())
  invoiceId         String
  patientId         String
  insuranceProvider String
  policyNumber      String
  claimAmount       Float
  approvedAmount    Float?
  status            ClaimStatus @default(SUBMITTED)
  submittedAt       DateTime    @default(now())
  resolvedAt        DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([invoiceId])
  @@index([patientId])
  @@map("insurance_claims")
}

// ─── NOTIFICATIONS ──────────────────────────────────────

model Notification {
  id        String              @id @default(uuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel
  title     String
  message   String
  data      Json?
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id      String              @id @default(uuid())
  userId  String
  channel NotificationChannel
  enabled Boolean             @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("notification_preferences")
}

// ─── AUDIT ──────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── SYSTEM ─────────────────────────────────────────────

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("system_config")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: IPD / INPATIENT MANAGEMENT
// ═══════════════════════════════════════════════════════

model Ward {
  id          String   @id @default(uuid())
  name        String   @unique
  type        WardType
  floor       String?
  description String?
  createdAt   DateTime @default(now())

  beds Bed[]

  @@map("wards")
}

model Bed {
  id        String    @id @default(uuid())
  wardId    String
  bedNumber String
  status    BedStatus @default(AVAILABLE)
  dailyRate Float     @default(0)
  notes     String?

  ward       Ward        @relation(fields: [wardId], references: [id])
  admissions Admission[]

  @@unique([wardId, bedNumber])
  @@index([status])
  @@map("beds")
}

model Admission {
  id               String          @id @default(uuid())
  admissionNumber  String          @unique
  patientId        String
  doctorId         String
  bedId            String
  status           AdmissionStatus @default(ADMITTED)
  admittedAt       DateTime        @default(now())
  dischargedAt     DateTime?
  reason           String
  diagnosis        String?
  dischargeSummary String?
  dischargeNotes   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  patient          Patient           @relation(fields: [patientId], references: [id])
  doctor           Doctor            @relation(fields: [doctorId], references: [id])
  bed              Bed               @relation(fields: [bedId], references: [id])
  ipdVitals        IpdVitals[]
  medicationOrders MedicationOrder[]
  nurseRounds      NurseRound[]
  labOrders        LabOrder[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@map("admissions")
}

model IpdVitals {
  id                     String   @id @default(uuid())
  admissionId            String
  recordedBy             String // user id
  bloodPressureSystolic  Int?
  bloodPressureDiastolic Int?
  temperature            Float?
  pulseRate              Int?
  respiratoryRate        Int?
  spO2                   Int?
  painScore              Int?
  bloodSugar             Int?
  notes                  String?
  recordedAt             DateTime @default(now())

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([admissionId, recordedAt])
  @@map("ipd_vitals")
}

model MedicationOrder {
  id           String    @id @default(uuid())
  admissionId  String
  doctorId     String
  medicineId   String? // link to medicine catalog
  medicineName String
  dosage       String
  frequency    String // e.g. "every 6 hours", "BID", "TID"
  route        String // oral, IV, IM, SC, topical
  startDate    DateTime  @default(now())
  endDate      DateTime?
  instructions String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  admission       Admission                  @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  doctor          Doctor                     @relation(fields: [doctorId], references: [id])
  medicine        Medicine?                  @relation(fields: [medicineId], references: [id])
  administrations MedicationAdministration[]

  @@index([admissionId])
  @@index([isActive])
  @@map("medication_orders")
}

model MedicationAdministration {
  id                String           @id @default(uuid())
  medicationOrderId String
  scheduledAt       DateTime
  administeredAt    DateTime?
  administeredBy    String? // nurse user id
  status            MedicationStatus @default(SCHEDULED)
  notes             String?

  medicationOrder MedicationOrder @relation(fields: [medicationOrderId], references: [id], onDelete: Cascade)
  nurse           User?           @relation(fields: [administeredBy], references: [id])

  @@index([medicationOrderId])
  @@index([scheduledAt, status])
  @@map("medication_administrations")
}

model NurseRound {
  id          String   @id @default(uuid())
  admissionId String
  nurseId     String
  notes       String
  performedAt DateTime @default(now())

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  nurse     User      @relation(fields: [nurseId], references: [id])

  @@index([admissionId])
  @@index([performedAt])
  @@map("nurse_rounds")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: MEDICINE DATABASE & DRUG INTERACTIONS
// ═══════════════════════════════════════════════════════

model Medicine {
  id                   String   @id @default(uuid())
  name                 String   @unique
  genericName          String?
  brand                String?
  form                 String? // tablet, syrup, injection, etc.
  strength             String? // "500mg", "250mg/5ml"
  category             String? // antibiotic, analgesic, etc.
  description          String?
  sideEffects          String?
  contraindications    String?
  prescriptionRequired Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  medicationOrders MedicationOrder[]
  interactionsA    DrugInteraction[] @relation("DrugA")
  interactionsB    DrugInteraction[] @relation("DrugB")
  inventoryItems   InventoryItem[]

  @@index([name])
  @@index([category])
  @@map("medicines")
}

model DrugInteraction {
  id          String @id @default(uuid())
  drugAId     String
  drugBId     String
  severity    String // MILD, MODERATE, SEVERE, CONTRAINDICATED
  description String

  drugA Medicine @relation("DrugA", fields: [drugAId], references: [id], onDelete: Cascade)
  drugB Medicine @relation("DrugB", fields: [drugBId], references: [id], onDelete: Cascade)

  @@unique([drugAId, drugBId])
  @@map("drug_interactions")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: PHARMACY INVENTORY
// ═══════════════════════════════════════════════════════

model InventoryItem {
  id           String   @id @default(uuid())
  medicineId   String
  batchNumber  String
  quantity     Int // current stock
  unitCost     Float // purchase cost per unit
  sellingPrice Float
  expiryDate   DateTime @db.Date
  supplier     String?
  reorderLevel Int      @default(10)
  location     String? // shelf/rack location
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  medicine  Medicine        @relation(fields: [medicineId], references: [id])
  movements StockMovement[]

  @@unique([medicineId, batchNumber])
  @@index([expiryDate])
  @@map("inventory_items")
}

model StockMovement {
  id              String            @id @default(uuid())
  inventoryItemId String
  type            StockMovementType
  quantity        Int // positive for in, negative for out
  referenceId     String? // e.g., prescription id, purchase order id
  reason          String?
  performedBy     String // user id
  createdAt       DateTime          @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  user          User          @relation(fields: [performedBy], references: [id])

  @@index([inventoryItemId])
  @@index([createdAt])
  @@map("stock_movements")
}

// ═══════════════════════════════════════════════════════
// PHASE 2: LAB TESTS
// ═══════════════════════════════════════════════════════

model LabTest {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., CBC, LFT
  name        String
  category    String? // Hematology, Biochemistry, Microbiology, etc.
  price       Float
  sampleType  String? // Blood, Urine, Stool
  normalRange String? // Free text for reference ranges
  description String?
  createdAt   DateTime @default(now())

  orderItems LabOrderItem[]

  @@index([code])
  @@index([category])
  @@map("lab_tests")
}

model LabOrder {
  id          String        @id @default(uuid())
  orderNumber String        @unique
  patientId   String
  doctorId    String
  admissionId String? // null for OPD
  status      LabTestStatus @default(ORDERED)
  notes       String?
  orderedAt   DateTime      @default(now())
  collectedAt DateTime?
  completedAt DateTime?

  patient   Patient        @relation(fields: [patientId], references: [id])
  doctor    Doctor         @relation(fields: [doctorId], references: [id])
  admission Admission?     @relation(fields: [admissionId], references: [id])
  items     LabOrderItem[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@map("lab_orders")
}

model LabOrderItem {
  id      String        @id @default(uuid())
  orderId String
  testId  String
  status  LabTestStatus @default(ORDERED)
  results LabResult[]

  order LabOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  test  LabTest  @relation(fields: [testId], references: [id])

  @@map("lab_order_items")
}

model LabResult {
  id          String        @id @default(uuid())
  orderItemId String
  parameter   String // e.g., "Hemoglobin", "WBC Count"
  value       String
  unit        String?
  normalRange String?
  flag        LabResultFlag @default(NORMAL)
  notes       String?
  enteredBy   String // user id
  reportedAt  DateTime      @default(now())

  orderItem LabOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("lab_results")
}
