  note            String?
  createdAt       DateTime @default(now())

  schedule        AdherenceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([patientId])
  @@index([patientId, scheduledAt])
  @@map("adherence_dose_logs")
}

// ─── LAB REPORT AI EXPLANATIONS ─────────────────────────

model LabReportExplanation {
  id             String   @id @default(uuid())
  labOrderId     String   @unique
  patientId      String
  explanation    String   @db.Text
  flaggedValues  Json     @default("[]") // [{ parameter, value, flag, plainLanguage }]
  language       String   @default("en")
  status         String   @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | SENT
  approvedBy     String?
  approvedAt     DateTime?
  sentAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([patientId])
  @@index([status])
  @@map("lab_report_explanations")
}

// ─── ABDM: ABHA LINKING / CONSENT / CARE CONTEXTS ───────

enum AbhaLinkStatus {
  PENDING
  VERIFIED
  LINKED
  REVOKED
  FAILED
}

enum ConsentStatus {
  REQUESTED
  GRANTED
  DENIED
  REVOKED
  EXPIRED
}

enum CareContextType {
  OPConsultation
  DischargeSummary
  DiagnosticReport
}

model AbhaLink {
  id            String         @id @default(uuid())
  patientId     String
  abhaAddress   String
  abhaNumber    String?
  status        AbhaLinkStatus @default(PENDING)
  requestId     String?        @unique
  linkedAt      DateTime?
  revokedAt     DateTime?
  failureReason String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([abhaAddress])
  @@index([status])
  @@map("abha_links")
}

model ConsentArtefact {
  id         String        @id @default(uuid())
  patientId  String
  hiuId      String
  purpose    String
  status     ConsentStatus @default(REQUESTED)
  artefact   Json
  expiresAt  DateTime
  grantedAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([status])
  @@index([expiresAt])
  @@map("consent_artefacts")
}

model CareContext {
  id             String          @id @default(uuid())
  patientId      String
  abhaAddress    String
  careContextRef String          @unique
  type           CareContextType
  lastPushedAt   DateTime?
  createdAt      DateTime        @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([abhaAddress])
  @@map("care_contexts")
}

// ─── INSURANCE TPA CLAIMS (v2) ──────────────────────────

enum TpaProvider {
  MEDI_ASSIST
  PARAMOUNT
  VIDAL
  FHPL
  ICICI_LOMBARD
  STAR_HEALTH
  MOCK
}

enum NormalisedClaimStatus {
  SUBMITTED
  IN_REVIEW
  QUERY_RAISED
  APPROVED
  PARTIALLY_APPROVED
  DENIED
  SETTLED
  CANCELLED
}

/// Richer TPA-aware claim model. Coexists with the legacy `InsuranceClaim`
/// (table `insurance_claims`); this one maps to `insurance_claims_v2`.
model InsuranceClaim2 {
  id               String                @id @default(uuid())
  billId           String
  patientId        String
  tpaProvider      TpaProvider
  providerClaimRef String?               @unique
  insurerName      String
  policyNumber     String
  memberId         String?
  preAuthRequestId String?
  diagnosis        String
  icd10Codes       Json?
  procedureName    String?
  admissionDate    DateTime?             @db.Date
  dischargeDate    DateTime?             @db.Date
  amountClaimed    Float
  amountApproved   Float?
  status           NormalisedClaimStatus @default(SUBMITTED)
  deniedReason     String?
  notes            String?
  submittedAt      DateTime              @default(now())
  approvedAt       DateTime?
  settledAt        DateTime?
  cancelledAt      DateTime?
  lastSyncedAt     DateTime?
  createdBy        String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  invoice        Invoice            @relation(fields: [billId], references: [id])
  patient        Patient            @relation(fields: [patientId], references: [id])
  preAuthRequest PreAuthRequest?    @relation(fields: [preAuthRequestId], references: [id])
  documents      ClaimDocument[]
  events         ClaimStatusEvent[]

  @@index([billId])
  @@index([patientId])
  @@index([tpaProvider, status])
  @@index([providerClaimRef])
  @@map("insurance_claims_v2")
}

model ClaimDocument {
  id            String   @id @default(uuid())
  claimId       String
  type          String
  fileKey       String
  filename      String
  contentType   String
  sizeBytes     Int
  providerDocId String?
  uploadedBy    String
  uploadedAt    DateTime @default(now())

  claim InsuranceClaim2 @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@map("claim_documents")
}

model ClaimStatusEvent {
  id        String                @id @default(uuid())
  claimId   String
  status    NormalisedClaimStatus
  timestamp DateTime              @default(now())
  note      String?
  source    String                @default("API")
  createdBy String?

  claim InsuranceClaim2 @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId, timestamp])
  @@map("claim_status_events")
}

// ─── RAG INGEST LOG ─────────────────────────────────────

model IngestLog {
  id           String   @id @default(uuid())
  sourceType   String
  sourceId     String
  patientId    String?
  doctorId     String?
  chunkCount   Int      @default(0)
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([sourceType, sourceId])
  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@map("ingest_logs")
}
