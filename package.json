{
  "name": "medcore",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:seed": "turbo db:seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run packages/shared apps/api/src/services",
    "test:web": "vitest run --config apps/web/vitest.config.ts",
    "test:coverage:web": "vitest run --config apps/web/vitest.config.ts --coverage",
    "test:coverage:unit": "vitest run apps/api/src/services packages/shared --coverage",
    "test:contract": "vitest run packages/shared/src/validation",
    "test:api": "vitest run apps/api/src/test/integration",
    "test:smoke": "vitest run apps/api/src/test/smoke.test.ts",
    "test:ai-eval": "RUN_AI_EVAL=1 vitest run apps/api/src/test/ai-eval/eval.test.ts",
    "test:ai-eval:unit": "vitest run apps/api/src/test/ai-eval/eval-runner.test.ts",
    "test:db:reset": "prisma db push --schema packages/db/prisma/schema.prisma --force-reset --skip-generate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:load": "tsx scripts/load-tests/run-load-test.ts",
    "test:load:mock": "tsx scripts/load-tests/mock-server.ts",
    "db:sanitize-reseed": "tsx scripts/sanitize-and-reseed.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.3",
    "@playwright/test": "^1.48.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.9",
    "supertest": "^7.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.4"
  },
  "overrides": {
    "react-test-renderer": "18.3.1"
  },
  "packageManager": "npm@10.5.0",
  "engines": {
    "node": ">=20"
  }
}
